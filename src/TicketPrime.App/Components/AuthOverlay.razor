@implements IDisposable
@inject AuthOverlayState Overlay
@inject TicketPrimeApiClient ApiClient
@inject UserSessionState Session
@inject NavigationManager Navigation

@if (Overlay.IsOpen)
{
    <div class="auth-overlay" @onclick="Close">
        <div class="auth-modal" @onclick:stopPropagation="true">
            <button class="auth-modal__close" type="button" @onclick="Close" aria-label="Fechar">x</button>

            <div class="auth-modal__layout">
                <aside class="auth-aside">
                    <span class="eyebrow">TicketPrime Access</span>
                    <h2>@AsideTitle</h2>
                    <p>
                        @AsideDescription
                    </p>

                    <div class="auth-aside__highlights">
                        <article>
                            <strong>Compra rapida</strong>
                            <span>Escolha assentos, carrinho e checkout no mesmo fluxo.</span>
                        </article>
                        <article>
                            <strong>Eventos em alta</strong>
                            <span>Shows, festivais e experiencias com curadoria visual.</span>
                        </article>
                        <article>
                            <strong>Sua conta centralizada</strong>
                            <span>Reservas, perfil e historico em um so lugar.</span>
                        </article>
                    </div>
                </aside>

                <section class="auth-panel">
                    <div class="auth-panel__head">
                        <span class="auth-panel__pill">Conta TicketPrime</span>
                        <h3>@PanelTitle</h3>
                        <p>
                            @if (IsLogin)
                            {
                                <span>Nao tem uma conta? <button class="auth-switch" type="button" @onclick="OpenRegister">Cadastre-se agora</button></span>
                            }
                            else if (IsRegister)
                            {
                                <span>Ja tem uma conta? <button class="auth-switch" type="button" @onclick="OpenLogin">Entrar agora</button></span>
                            }
                            else if (IsForgot)
                            {
                                <span>Lembrou da senha? <button class="auth-switch" type="button" @onclick="OpenLogin">Voltar para o login</button></span>
                            }
                            else
                            {
                                <span>Recebeu o codigo? <button class="auth-switch" type="button" @onclick="OpenLogin">Voltar para o login</button></span>
                            }
                        </p>
                    </div>

                    @if (!IsForgot && !IsReset)
                    {
                        <div class="auth-tabs" role="tablist" aria-label="Tipo de acesso">
                            <button class="auth-tab @(IsLogin ? "auth-tab--active" : null)" type="button" @onclick="OpenLogin">Entrar</button>
                            <button class="auth-tab @(IsRegister ? "auth-tab--active" : null)" type="button" @onclick="OpenRegister">Criar conta</button>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(statusMessage))
                    {
                        <div class="status-box @(isError ? "status-box--error" : "status-box--success")">@statusMessage</div>
                    }

                    @if (IsLogin)
                    {
                        <EditForm Model="@loginModel" OnValidSubmit="HandleLogin" FormName="overlay-login" class="auth-form">
                            <DataAnnotationsValidator />

                            <div class="field">
                                <label for="overlayLogin">E-mail ou CPF</label>
                                <InputText id="overlayLogin" class="field__input" @bind-Value="loginModel.Login" placeholder="Digite seu e-mail ou CPF" />
                                <ValidationMessage For="() => loginModel.Login" />
                            </div>

                            <div class="field">
                                <label for="overlaySenha">Senha</label>
                                <InputText id="overlaySenha" class="field__input" type="password" @bind-Value="loginModel.Senha" placeholder="Digite sua senha" />
                                <ValidationMessage For="() => loginModel.Senha" />
                            </div>

                            <button class="auth-switch auth-switch--inline" type="button" @onclick="OpenForgotPassword">Esqueci minha senha</button>

                            <button class="auth-submit" type="submit" disabled="@isBusy">
                                @(isBusy ? "Entrando..." : "Entrar na conta")
                            </button>

                            @if (CanSuggestPasswordReset)
                            {
                                <button class="auth-secondary" type="button" @onclick="OpenForgotPassword">Redefinir senha</button>
                            }
                        </EditForm>
                    }
                    else if (IsRegister)
                    {
                        <EditForm Model="@registerModel" OnValidSubmit="HandleRegister" FormName="overlay-register" class="auth-form">
                            <DataAnnotationsValidator />

                            <div class="field">
                                <label for="overlayCpf">CPF</label>
                                <InputText id="overlayCpf" class="field__input" @bind-Value="registerModel.Cpf" placeholder="000.000.000-00" />
                                <ValidationMessage For="() => registerModel.Cpf" />
                            </div>

                            <div class="field auth-form__grid">
                                <div>
                                    <label for="overlayNome">Nome</label>
                                    <InputText id="overlayNome" class="field__input" @bind-Value="registerModel.Nome" placeholder="Seu nome" />
                                    <ValidationMessage For="() => registerModel.Nome" />
                                </div>
                                <div>
                                    <label for="overlayEmail">E-mail</label>
                                    <InputText id="overlayEmail" class="field__input" @bind-Value="registerModel.Email" placeholder="voce@email.com" />
                                    <ValidationMessage For="() => registerModel.Email" />
                                </div>
                            </div>

                            <div class="field auth-form__grid">
                                <div>
                                    <label for="overlayConfirmarEmail">Confirmar e-mail</label>
                                    <InputText id="overlayConfirmarEmail" class="field__input" @bind-Value="registerModel.ConfirmarEmail" placeholder="Repita seu e-mail" />
                                    <ValidationMessage For="() => registerModel.ConfirmarEmail" />
                                    @if (EmailConfirmationMismatch)
                                    {
                                        <span class="field__hint field__hint--error">Os e-mails informados nao coincidem.</span>
                                    }
                                </div>
                                <div>
                                    <label for="overlayCadastroSenha">Senha</label>
                                    <InputText id="overlayCadastroSenha" class="field__input" type="password" @bind-Value="registerModel.Senha" placeholder="Crie uma senha segura" />
                                    <ValidationMessage For="() => registerModel.Senha" />
                                </div>
                            </div>

                            <div class="field">
                                <label for="overlayConfirmarSenha">Confirmar senha</label>
                                <InputText id="overlayConfirmarSenha" class="field__input" type="password" @bind-Value="registerModel.ConfirmarSenha" placeholder="Repita sua senha" />
                                <ValidationMessage For="() => registerModel.ConfirmarSenha" />
                                @if (PasswordConfirmationMismatch)
                                {
                                    <span class="field__hint field__hint--error">As senhas informadas nao coincidem.</span>
                                }
                            </div>

                            <button class="auth-submit" type="submit" disabled="@isBusy">
                                @(isBusy ? "Criando conta..." : "Cadastrar e entrar")
                            </button>

                            @if (CanSuggestPasswordReset)
                            {
                                <button class="auth-secondary" type="button" @onclick="OpenForgotPasswordWithRegisterEmail">Ja tenho uma conta e quero redefinir a senha</button>
                            }
                        </EditForm>
                    }
                    else if (IsForgot)
                    {
                        <EditForm Model="@forgotPasswordModel" OnValidSubmit="HandleForgotPassword" FormName="overlay-forgot" class="auth-form">
                            <DataAnnotationsValidator />

                            <div class="field">
                                <label for="overlayForgotLogin">E-mail ou CPF</label>
                                <InputText id="overlayForgotLogin" class="field__input" @bind-Value="forgotPasswordModel.Login" placeholder="Digite o e-mail ou CPF da conta" />
                                <ValidationMessage For="() => forgotPasswordModel.Login" />
                            </div>

                            <button class="auth-submit" type="submit" disabled="@isBusy">
                                @(isBusy ? "Enviando codigo..." : "Enviar codigo de redefinicao")
                            </button>
                        </EditForm>
                    }
                    else
                    {
                        <EditForm Model="@resetPasswordModel" OnValidSubmit="HandleResetPassword" FormName="overlay-reset" class="auth-form">
                            <DataAnnotationsValidator />

                            @if (!string.IsNullOrWhiteSpace(recoveryMaskedEmail))
                            {
                                <div class="status-box status-box--success">Enviamos um codigo para @recoveryMaskedEmail.</div>
                            }

                            <div class="field">
                                <label for="overlayResetCode">Codigo recebido por e-mail</label>
                                <InputText id="overlayResetCode" class="field__input" @bind-Value="resetPasswordModel.Codigo" placeholder="Digite o codigo de 6 digitos" />
                                <ValidationMessage For="() => resetPasswordModel.Codigo" />
                            </div>

                            <div class="field auth-form__grid">
                                <div>
                                    <label for="overlayNovaSenha">Nova senha</label>
                                    <InputText id="overlayNovaSenha" class="field__input" type="password" @bind-Value="resetPasswordModel.NovaSenha" placeholder="Crie sua nova senha" />
                                    <ValidationMessage For="() => resetPasswordModel.NovaSenha" />
                                </div>
                                <div>
                                    <label for="overlayConfirmarNovaSenha">Confirmar nova senha</label>
                                    <InputText id="overlayConfirmarNovaSenha" class="field__input" type="password" @bind-Value="resetPasswordModel.ConfirmarSenha" placeholder="Repita a nova senha" />
                                    <ValidationMessage For="() => resetPasswordModel.ConfirmarSenha" />
                                    @if (ResetPasswordMismatch)
                                    {
                                        <span class="field__hint field__hint--error">As novas senhas nao coincidem.</span>
                                    }
                                </div>
                            </div>

                            <button class="auth-submit" type="submit" disabled="@isBusy">
                                @(isBusy ? "Atualizando senha..." : "Salvar nova senha")
                            </button>

                            <button class="auth-secondary" type="button" @onclick="ResendResetCodeAsync" disabled="@isBusy">
                                Solicitar novo codigo
                            </button>
                        </EditForm>
                    }
                </section>
            </div>
        </div>
    </div>
}

@code {
    private readonly CustomerLoginInputModel loginModel = new();
    private readonly RegisterInputModel registerModel = new();
    private readonly ForgotPasswordInputModel forgotPasswordModel = new();
    private readonly ResetPasswordInputModel resetPasswordModel = new();
    private bool isBusy;
    private bool isError;
    private string statusMessage = string.Empty;
    private string recoveryMaskedEmail = string.Empty;

    private bool IsLogin => Overlay.Mode == "login";
    private bool IsRegister => Overlay.Mode == "register";
    private bool IsForgot => Overlay.Mode == "forgot";
    private bool IsReset => Overlay.Mode == "reset";
    private string PanelTitle =>
        IsLogin ? "Acesse a sua conta" :
        IsRegister ? "Crie sua conta" :
        IsForgot ? "Recupere sua senha" :
        "Defina uma nova senha";
    private string AsideTitle =>
        IsLogin ? "Seu proximo evento comeca aqui." :
        IsRegister ? "Crie sua conta e entre no ritmo." :
        IsForgot ? "Recupere o acesso a sua conta." :
        "Escolha uma nova senha com seguranca.";
    private string AsideDescription =>
        IsLogin
            ? "Acesse seus ingressos, acompanhe reservas e continue a compra sem perder tempo."
            : IsRegister
                ? "Monte sua conta em poucos passos para garantir assentos, acompanhar pedidos e explorar a agenda completa."
                : IsForgot
                    ? "Informe o e-mail ou CPF cadastrado para receber um codigo de verificacao no Gmail configurado da sua conta."
                    : "Use o codigo enviado por e-mail para confirmar sua identidade e concluir a redefinicao da senha.";
    private bool EmailConfirmationMismatch =>
        !string.IsNullOrWhiteSpace(registerModel.Email) &&
        !string.IsNullOrWhiteSpace(registerModel.ConfirmarEmail) &&
        !string.Equals(registerModel.Email.Trim(), registerModel.ConfirmarEmail.Trim(), StringComparison.OrdinalIgnoreCase);

    private bool PasswordConfirmationMismatch =>
        !string.IsNullOrWhiteSpace(registerModel.Senha) &&
        !string.IsNullOrWhiteSpace(registerModel.ConfirmarSenha) &&
        !string.Equals(registerModel.Senha, registerModel.ConfirmarSenha, StringComparison.Ordinal);
    private bool ResetPasswordMismatch =>
        !string.IsNullOrWhiteSpace(resetPasswordModel.NovaSenha) &&
        !string.IsNullOrWhiteSpace(resetPasswordModel.ConfirmarSenha) &&
        !string.Equals(resetPasswordModel.NovaSenha, resetPasswordModel.ConfirmarSenha, StringComparison.Ordinal);
    private bool CanSuggestPasswordReset =>
        isError &&
        ((IsLogin && statusMessage.Contains("Senha", StringComparison.OrdinalIgnoreCase)) ||
         (IsRegister && statusMessage.Contains("Ja existe uma conta", StringComparison.OrdinalIgnoreCase)));

    protected override void OnInitialized()
    {
        Overlay.OnChange += HandleOverlayChanged;
    }

    private void HandleOverlayChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OpenLogin()
    {
        statusMessage = string.Empty;
        isError = false;
        recoveryMaskedEmail = string.Empty;
        Overlay.OpenLogin();
    }

    private void OpenRegister()
    {
        statusMessage = string.Empty;
        isError = false;
        recoveryMaskedEmail = string.Empty;
        Overlay.OpenRegister();
    }

    private void OpenForgotPassword()
    {
        statusMessage = string.Empty;
        isError = false;
        recoveryMaskedEmail = string.Empty;
        forgotPasswordModel.Login = loginModel.Login;
        Overlay.OpenForgotPassword();
    }

    private void OpenForgotPasswordWithRegisterEmail()
    {
        statusMessage = string.Empty;
        isError = false;
        recoveryMaskedEmail = string.Empty;
        forgotPasswordModel.Login = !string.IsNullOrWhiteSpace(registerModel.Email)
            ? registerModel.Email
            : registerModel.Cpf;
        Overlay.OpenForgotPassword();
    }

    private void OpenResetPassword()
    {
        statusMessage = string.Empty;
        isError = false;
        Overlay.OpenResetPassword();
    }

    private void Close()
    {
        statusMessage = string.Empty;
        isError = false;
        recoveryMaskedEmail = string.Empty;
        Overlay.Close();
    }

    private async Task HandleLogin()
    {
        statusMessage = string.Empty;
        isError = false;
        isBusy = true;

        try
        {
            var result = await ApiClient.LoginUserAsync(new UserLoginRequest
            {
                Login = loginModel.Login,
                Senha = loginModel.Senha
            });

            if (!result.Sucesso)
            {
                isError = true;
                statusMessage = result.Mensagem;
                return;
            }

            if (result.Perfil == "admin" && !string.IsNullOrWhiteSpace(result.Token))
            {
                Session.SetAdmin(result.Token);
                Overlay.Close();
                Navigation.NavigateTo("/admin");
                return;
            }

            Session.SetUser(new UserViewModel
            {
                Cpf = result.Cpf ?? string.Empty,
                Nome = result.Nome ?? string.Empty,
                Email = result.Email ?? string.Empty
            });

            Overlay.Close();
            Navigation.NavigateTo("/eventos");
        }
        catch
        {
            isError = true;
            statusMessage = "Nao conseguimos conectar ao sistema neste momento.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task HandleRegister()
    {
        statusMessage = string.Empty;
        isError = false;

        if (EmailConfirmationMismatch)
        {
            isError = true;
            statusMessage = "Os e-mails informados nao coincidem.";
            return;
        }

        if (PasswordConfirmationMismatch)
        {
            isError = true;
            statusMessage = "As senhas informadas nao coincidem.";
            return;
        }

        isBusy = true;

        try
        {
            var result = await ApiClient.RegisterUserAsync(new UserCreateRequest
            {
                Cpf = registerModel.Cpf,
                Nome = registerModel.Nome,
                Email = registerModel.Email,
                Senha = registerModel.Senha
            });

            if (!result.Sucesso)
            {
                isError = true;
                statusMessage = result.Mensagem;
                return;
            }

            Session.SetUser(new UserViewModel
            {
                Cpf = result.Cpf ?? registerModel.Cpf,
                Nome = result.Nome ?? registerModel.Nome,
                Email = result.Email ?? registerModel.Email
            });

            Overlay.Close();
            Navigation.NavigateTo("/eventos");
        }
        catch
        {
            isError = true;
            statusMessage = "Seu cadastro nao foi concluido agora.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task HandleForgotPassword()
    {
        statusMessage = string.Empty;
        isError = false;
        isBusy = true;

        try
        {
            var result = await ApiClient.RequestPasswordResetAsync(new ForgotPasswordRequest
            {
                Login = forgotPasswordModel.Login
            });

            if (!result.Sucesso)
            {
                isError = true;
                statusMessage = result.Mensagem;
                return;
            }

            recoveryMaskedEmail = result.EmailMascarado;
            resetPasswordModel.Login = forgotPasswordModel.Login;
            resetPasswordModel.Codigo = string.Empty;
            resetPasswordModel.NovaSenha = string.Empty;
            resetPasswordModel.ConfirmarSenha = string.Empty;
            statusMessage = result.Mensagem;
            isError = false;
            OpenResetPassword();
            recoveryMaskedEmail = result.EmailMascarado;
            statusMessage = result.Mensagem;
        }
        catch
        {
            isError = true;
            statusMessage = "Nao conseguimos iniciar a recuperacao agora.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task HandleResetPassword()
    {
        statusMessage = string.Empty;
        isError = false;

        if (ResetPasswordMismatch)
        {
            isError = true;
            statusMessage = "As novas senhas nao coincidem.";
            return;
        }

        isBusy = true;

        try
        {
            var novaSenha = resetPasswordModel.NovaSenha;
            var result = await ApiClient.ResetPasswordAsync(new ResetPasswordRequest
            {
                Login = resetPasswordModel.Login,
                Codigo = resetPasswordModel.Codigo,
                NovaSenha = novaSenha
            });

            if (!result.Sucesso)
            {
                isError = true;
                statusMessage = result.Mensagem;
                return;
            }

            loginModel.Login = resetPasswordModel.Login;
            loginModel.Senha = novaSenha;
            statusMessage = result.Mensagem;
            recoveryMaskedEmail = string.Empty;
            resetPasswordModel.Codigo = string.Empty;
            resetPasswordModel.NovaSenha = string.Empty;
            resetPasswordModel.ConfirmarSenha = string.Empty;
            OpenLogin();
            statusMessage = result.Mensagem;
        }
        catch
        {
            isError = true;
            statusMessage = "Nao conseguimos redefinir a senha agora.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task ResendResetCodeAsync()
    {
        forgotPasswordModel.Login = resetPasswordModel.Login;
        await HandleForgotPassword();
    }

    public void Dispose()
    {
        Overlay.OnChange -= HandleOverlayChanged;
    }
}
