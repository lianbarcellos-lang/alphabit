@page "/reservas"
@inject AlphabitApiClient ApiClient
@inject UserSessionState Session
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using System.Text
@using QRCoder

<PageTitle>Minhas Reservas</PageTitle>

@if (Session.CurrentUser is null)
{
    <div class="reservations-shell">
        <div class="status-box status-box--error">Entre com uma conta de cliente para visualizar suas reservas.</div>
        <button class="ghost-button" @onclick='() => Navigation.NavigateTo("/eventos")'>Ir para eventos</button>
    </div>
}
else
{
    <div class="reservations-shell">
        <section class="reservations-hero">
            <div>
                <span class="eyebrow">Minhas reservas</span>
                <h1>Seus ingressos confirmados</h1>
                <p>Acompanhe as compras já registradas no seu CPF e veja o resumo de cada reserva.</p>
            </div>
            <button class="ghost-button" @onclick='() => Navigation.NavigateTo("/eventos")'>Voltar aos eventos</button>
        </section>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="status-box status-box--error">@errorMessage</div>
        }
        else if (isLoading)
        {
            <div class="status-box">Carregando suas reservas...</div>
        }
        else if (reservations.Count == 0)
        {
            <div class="status-box">Você ainda não possui reservas confirmadas.</div>
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(reviewMessage))
            {
                <div class="status-box @(reviewIsError ? "status-box--error" : "status-box--success")">@reviewMessage</div>
            }

            <section class="reservations-grid">
                @foreach (var item in reservations)
                {
                    <article class="reservation-card">
                        <span class="pill">@item.EventoNome</span>
                        <h2>@item.Quantidade ingresso(s)</h2>
                        <p>Tipo: <strong>@(string.IsNullOrWhiteSpace(item.TipoIngressoNome) ? "Normal" : item.TipoIngressoNome)</strong></p>
                        <p>Reserva: <strong>@GetReservationMode(item)</strong></p>
                        <p>@item.DataReserva.ToString("dd/MM/yyyy 'as' HH:mm")</p>
                        <p>Valor pago: <strong>R$ @item.ValorFinalPago.ToString("0.00")</strong></p>
                        <p>Check-in: <strong>@item.CheckinStatus</strong></p>
                        <div class="reservation-actions">
                            <button class="reservation-map-button"
                                    type="button"
                                    disabled="@mapIsLoading"
                                    @onclick="() => OpenEventMap(item)">
                                Ver mapa do evento
                            </button>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(item.QrCode))
                        {
                            <div class="reservation-ticket">
                                <div class="reservation-ticket__qr">
                                    <img src="@GetQrCodeDataUrl(item.QrCode)" alt="QR Code da reserva @item.Id" />
                                </div>
                                <div>
                                    <span>QR Code de entrada</span>
                                    <strong class="reservation-qr">@item.QrCode</strong>
                                    <button class="reservation-ticket__button" type="button" @onclick="() => OpenExpandedQrCode(item.Id)">Abrir</button>
                                </div>
                            </div>

                            @if (expandedQrReservationId == item.Id)
                            {
                                <div class="reservation-qr-expanded">
                                    <div class="reservation-qr-expanded__head">
                                        <strong>QR Code para leitura</strong>
                                        <button class="reservation-ticket__button" type="button" @onclick="CloseExpandedQrCode">Fechar</button>
                                    </div>
                                    <img src="@GetQrCodeDataUrl(item.QrCode)" alt="QR Code ampliado da reserva @item.Id" />
                                    <span>@item.QrCode</span>
                                </div>
                            }
                        }
                        @if (item.DataCheckin is not null)
                        {
                            <p>Validado em: <strong>@item.DataCheckin.Value.ToString("dd/MM/yyyy 'as' HH:mm")</strong></p>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.CupomUtilizado))
                        {
                            <p>Cupom aplicado: <strong>@item.CupomUtilizado</strong></p>
                        }

                        <div class="reservation-review">
                            <h3>Avaliar evento</h3>
                            @if (reviewedEventIds.Contains(item.EventoId))
                            {
                                <p>Você já avaliou este evento.</p>
                            }
                            else
                            {
                                <label for="@($"review-note-{item.Id}")">Nota</label>
                                <select id="@($"review-note-{item.Id}")"
                                        class="reservation-review__select"
                                        value="@GetReviewRating(item.Id)"
                                        @onchange="eventArgs => SetReviewRating(item.Id, eventArgs.Value?.ToString())">
                                    <option value="5">5 - Excelente</option>
                                    <option value="4">4 - Muito bom</option>
                                    <option value="3">3 - Bom</option>
                                    <option value="2">2 - Regular</option>
                                    <option value="1">1 - Ruim</option>
                                </select>

                                <label for="@($"review-comment-{item.Id}")">Comentario</label>
                                <textarea id="@($"review-comment-{item.Id}")"
                                          class="reservation-review__textarea"
                                          maxlength="600"
                                          value="@GetReviewComment(item.Id)"
                                          @oninput="eventArgs => SetReviewComment(item.Id, eventArgs.Value?.ToString())"></textarea>

                                <button class="secondary-button"
                                        type="button"
                                        disabled="@reviewIsBusy"
                                        @onclick="() => SubmitReview(item)">
                                    Enviar avaliação
                                </button>
                            }
                        </div>
                    </article>
                }
            </section>
        }

        @if (selectedMapEventId is not null)
        {
            <div class="reservation-map-modal" role="dialog" aria-modal="true" aria-labelledby="reservation-map-title">
                <div class="reservation-map-modal__backdrop" @onclick="CloseEventMap"></div>
                <section class="reservation-map-modal__panel">
                    <div class="reservation-map-modal__head">
                        <div>
                            <span class="eyebrow">Mapa do evento</span>
                            <h2 id="reservation-map-title">@selectedMapEventName</h2>
                            <p>Planta oficial configurada pelo administrador.</p>
                        </div>
                        <button class="reservation-map-modal__close" type="button" @onclick="CloseEventMap">Fechar</button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(mapErrorMessage))
                    {
                        <div class="status-box status-box--error">@mapErrorMessage</div>
                    }
                    else if (mapIsLoading)
                    {
                        <div class="status-box">Carregando mapa do evento...</div>
                    }
                    else if (selectedMapStands.Count == 0)
                    {
                        <div class="status-box">Este evento ainda não possui mapa de stands cadastrado.</div>
                    }
                    else
                    {
                        <div class="reservation-map-modal__actions">
                            <button class="reservation-map-print"
                                    type="button"
                                    @onclick="PrintEventMap">
                                Salvar mapa em PDF
                            </button>
                            <a class="reservation-map-download"
                               href="@BuildMapDownloadHref()"
                               download="@BuildMapDownloadFileName()">
                                Baixar resumo
                            </a>
                        </div>

                        @if (HasSelectedMapImage)
                        {
                            <div class="reservation-stand-image-map">
                                <img src="@SelectedMapImageUrl" alt="Planta do evento @selectedMapEventName" />
                                @foreach (var stand in selectedMapStands)
                                {
                                    <article class="reservation-stand-pin @(stand.Reservado ? "reservation-stand-pin--reserved" : null)"
                                             @key="stand.Id"
                                             style="@BuildReservationStandPinStyle(stand)"
                                             title="@BuildReservationStandTitle(stand)">
                                        <strong>@stand.Codigo</strong>
                                    </article>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="reservation-stand-map" style="@BuildReservationStandMapStyle()">
                                @foreach (var stand in selectedMapStands)
                                {
                                    <article class="reservation-stand-block @(stand.Reservado ? "reservation-stand-block--reserved" : null)"
                                             @key="stand.Id"
                                             style="@BuildReservationStandStyle(stand)">
                                        <span>@stand.Codigo</span>
                                        <strong>@(stand.Reservado ? stand.NomeOcupante : "Livre")</strong>
                                        <small>@stand.Setor</small>
                                    </article>
                                }
                            </div>
                        }

                        <div class="reservation-stand-legend">
                            @foreach (var stand in selectedMapStands.OrderBy(stand => stand.Codigo))
                            {
                                <article>
                                    <strong>@stand.Codigo</strong>
                                    <span>@(stand.Reservado ? $"{stand.NomeOcupante} - {stand.TipoOcupante}" : "Disponível")</span>
                                </article>
                            }
                        </div>
                    }
                </section>
            </div>
        }
    </div>
}

@code {
    private readonly List<ReservationViewModel> reservations = [];
    private readonly Dictionary<int, int> reviewRatings = [];
    private readonly Dictionary<int, string> reviewComments = [];
    private readonly HashSet<int> reviewedEventIds = [];
    private bool isLoading = true;
    private bool reviewIsBusy;
    private bool reviewIsError;
    private string errorMessage = string.Empty;
    private string reviewMessage = string.Empty;
    private int? expandedQrReservationId;
    private readonly List<StandSpaceViewModel> selectedMapStands = [];
    private int? selectedMapEventId;
    private string selectedMapEventName = string.Empty;
    private string selectedMapEventCity = string.Empty;
    private string mapErrorMessage = string.Empty;
    private bool mapIsLoading;

    private static string GetQrCodeDataUrl(string payload)
    {
        using var generator = new QRCodeGenerator();
        using var data = generator.CreateQrCode(payload, QRCodeGenerator.ECCLevel.Q);
        var qrCode = new SvgQRCode(data);
        var svg = qrCode.GetGraphic(8);
        return $"data:image/svg+xml;base64,{Convert.ToBase64String(Encoding.UTF8.GetBytes(svg))}";
    }

    private void OpenExpandedQrCode(int reservationId)
    {
        expandedQrReservationId = reservationId;
    }

    private void CloseExpandedQrCode()
    {
        expandedQrReservationId = null;
    }

    private async Task OpenEventMap(ReservationViewModel reservation)
    {
        selectedMapEventId = reservation.EventoId;
        selectedMapEventName = reservation.EventoNome;
        selectedMapEventCity = reservation.EventoCidade;
        selectedMapStands.Clear();
        mapErrorMessage = string.Empty;
        mapIsLoading = true;

        try
        {
            selectedMapStands.AddRange(await ApiClient.GetEventStandsAsync(reservation.EventoId));
        }
        catch
        {
            mapErrorMessage = "Não foi possível carregar o mapa deste evento agora.";
        }
        finally
        {
            mapIsLoading = false;
        }
    }

    private void CloseEventMap()
    {
        selectedMapEventId = null;
        selectedMapEventName = string.Empty;
        selectedMapEventCity = string.Empty;
        selectedMapStands.Clear();
        mapErrorMessage = string.Empty;
        mapIsLoading = false;
    }

    private string BuildReservationStandMapStyle()
    {
        var maxColumn = Math.Max(4, selectedMapStands.Count == 0 ? 4 : selectedMapStands.Max(stand => stand.PosicaoX + stand.Largura - 1));
        var maxRow = Math.Max(7, selectedMapStands.Count == 0 ? 7 : selectedMapStands.Max(stand => stand.PosicaoY + stand.Altura - 1));
        return $"--stand-columns:{maxColumn};--stand-rows:{maxRow};";
    }

    private static string BuildReservationStandStyle(StandSpaceViewModel stand)
    {
        return $"grid-column:{stand.PosicaoX} / span {Math.Max(1, stand.Largura)};grid-row:{stand.PosicaoY} / span {Math.Max(1, stand.Altura)};";
    }

    private string SelectedMapImageUrl => selectedMapStands.FirstOrDefault(stand => !string.IsNullOrWhiteSpace(stand.MapaImagemUrl))?.MapaImagemUrl ?? string.Empty;

    private bool HasSelectedMapImage => !string.IsNullOrWhiteSpace(SelectedMapImageUrl);

    private static string BuildReservationStandPinStyle(StandSpaceViewModel stand)
    {
        var left = Math.Clamp(stand.AreaX <= 0 ? 50 : stand.AreaX, 0, 100);
        var top = Math.Clamp(stand.AreaY <= 0 ? 50 : stand.AreaY, 0, 100);
        return FormattableString.Invariant($"left:{left:0.###}%;top:{top:0.###}%;");
    }

    private static string BuildReservationStandTitle(StandSpaceViewModel stand)
    {
        var status = stand.Reservado && !string.IsNullOrWhiteSpace(stand.NomeOcupante)
            ? $"{stand.NomeOcupante} - {stand.TipoOcupante}"
            : "Disponível";

        return $"{stand.Codigo} | {stand.Setor} | {status}";
    }

    private async Task PrintEventMap()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private string BuildMapDownloadFileName()
    {
        return BuildSafeMapFileName("txt");
    }

    private string BuildSafeMapFileName(string extension)
    {
        var safeName = new string(selectedMapEventName
            .Select(character => char.IsLetterOrDigit(character) ? character : '-')
            .ToArray())
            .Trim('-');

        return $"mapa-{(string.IsNullOrWhiteSpace(safeName) ? "evento" : safeName.ToLowerInvariant())}.{extension}";
    }

    private string BuildMapDownloadHref()
    {
        var builder = new StringBuilder();
        builder.AppendLine($"Mapa do evento: {selectedMapEventName}");
        if (!string.IsNullOrWhiteSpace(selectedMapEventCity))
            builder.AppendLine($"Cidade/modelo: {selectedMapEventCity}");
        builder.AppendLine();

        foreach (var sector in selectedMapStands.GroupBy(stand => stand.Setor))
        {
            builder.AppendLine(sector.Key);
            foreach (var stand in sector.OrderBy(item => item.Codigo))
            {
                var occupant = stand.Reservado ? $"{stand.NomeOcupante} - {stand.TipoOcupante}" : "Disponível";
                builder.AppendLine($"{stand.Codigo}: {occupant}");
            }

            builder.AppendLine();
        }

        return $"data:text/plain;charset=utf-8,{Uri.EscapeDataString(builder.ToString())}";
    }

    protected override async Task OnInitializedAsync()
    {
        if (Session.CurrentUser is null)
        {
            isLoading = false;
            return;
        }

        try
        {
            reservations.Clear();
            reservations.AddRange(await ApiClient.GetReservationsAsync(Session.CurrentUser.Cpf));
            foreach (var reservation in reservations)
            {
                reviewRatings.TryAdd(reservation.Id, 5);
            }

            await LoadReviewedEventsForReservations();
        }
        catch
        {
            errorMessage = "Não foi possível carregar suas reservas agora.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private int GetReviewRating(int reservationId)
    {
        return reviewRatings.TryGetValue(reservationId, out var rating) ? rating : 5;
    }

    private string GetReviewComment(int reservationId)
    {
        return reviewComments.TryGetValue(reservationId, out var comment) ? comment : string.Empty;
    }

    private void SetReviewRating(int reservationId, string? value)
    {
        reviewRatings[reservationId] = int.TryParse(value, out var rating)
            ? Math.Clamp(rating, 1, 5)
            : 5;
    }

    private void SetReviewComment(int reservationId, string? value)
    {
        reviewComments[reservationId] = value ?? string.Empty;
    }

    private static string GetReservationMode(ReservationViewModel item)
    {
        return string.IsNullOrWhiteSpace(item.Assentos)
            ? "Entrada geral sem assento marcado"
            : $"Assentos: {item.Assentos}";
    }

    private async Task LoadReviewedEventsForReservations()
    {
        if (Session.CurrentUser is null)
            return;

        reviewedEventIds.Clear();
        var eventIds = reservations
            .Select(reservation => reservation.EventoId)
            .Distinct()
            .ToList();

        foreach (var eventId in eventIds)
        {
            var reviews = await ApiClient.GetEventReviewsAsync(eventId);
            if (reviews.Any(review => string.Equals(review.UsuarioCpf, Session.CurrentUser.Cpf, StringComparison.Ordinal)))
                reviewedEventIds.Add(eventId);
        }
    }

    private async Task SubmitReview(ReservationViewModel reservation)
    {
        if (Session.CurrentUser is null)
            return;

        reviewIsBusy = true;
        reviewIsError = false;
        reviewMessage = string.Empty;

        try
        {
            var result = await ApiClient.CreateEventReviewAsync(new EventReviewRequest
            {
                EventoId = reservation.EventoId,
                UsuarioCpf = Session.CurrentUser.Cpf,
                Nota = GetReviewRating(reservation.Id),
                Comentario = GetReviewComment(reservation.Id)
            }, Session.CurrentUser.Cpf);

            reviewIsError = !result.Success;
            reviewMessage = result.Message;

            if (result.Success)
                reviewedEventIds.Add(reservation.EventoId);
        }
        catch
        {
            reviewIsError = true;
            reviewMessage = "Não foi possível enviar a avaliação agora.";
        }
        finally
        {
            reviewIsBusy = false;
        }
    }
}
