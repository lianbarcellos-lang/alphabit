@page "/"
@page "/eventos"
@inject AlphabitApiClient ApiClient
@inject UserSessionState Session
@inject NavigationManager Navigation
@inject EventSearchState EventSearch
@implements IDisposable

<PageTitle>Eventos</PageTitle>

<div class="events-shell">
    <section class="events-featured">
        <div class="events-featured__head">
            <div>
                <h1>Eventos em destaque</h1>
            </div>
        </div>

        @if (isLoading)
        {
            <div class="events-featured__empty">Carregando destaques...</div>
        }
        else if (featuredEvents.Count == 0)
        {
            <div class="events-featured__empty">Nenhum evento em destaque no momento.</div>
        }
        else
        {
            <div class="featured-carousel" aria-label="Eventos em destaque">
                @if (featuredEvents.Count > 1)
                {
                    <button class="featured-carousel__arrow featured-carousel__arrow--prev"
                            type="button"
                            aria-label="Voltar destaque"
                            @onclick="PreviousFeatured">
                        ‹
                    </button>
                }

                <div class="featured-carousel__track">
                    @foreach (var item in GetVisibleFeaturedItems())
                    {
                        <article class="featured-card"
                                 tabindex="0"
                                 role="link"
                                 @onclick="() => OpenEvent(item.Id)"
                                 @onkeydown="args => HandleEventCardKeyDown(args, item.Id)">
                            @if (!string.IsNullOrWhiteSpace(item.ImagemUrl))
                            {
                                <img src="@item.ImagemUrl" alt="@item.Nome" />
                            }
                            <div class="featured-card__shade"></div>
                            <div class="featured-card__content">
                                <span class="pill">@GetCategory(item)</span>
                                <h2>@item.Nome</h2>
                                <strong>@item.Artista</strong>
                                <p>@item.LocalEvento, @item.CidadeEvento • @item.DataEvento.ToString("dd/MM/yyyy 'as' HH:mm")</p>
                                <button class="buy-button" type="button" @onclick:stopPropagation="true" @onclick="() => OpenEvent(item.Id)">Ver ingressos</button>
                            </div>
                        </article>
                    }
                </div>

                @if (featuredEvents.Count > 1)
                {
                    <button class="featured-carousel__arrow featured-carousel__arrow--next"
                            type="button"
                            aria-label="Avançar destaque"
                            @onclick="NextFeatured">
                        ›
                    </button>
                }
            </div>
        }
    </section>

    <section class="events-filters">
        <div class="field">
            <label for="filtroCidade">Cidade</label>
            <select id="filtroCidade" class="field__input" @bind="selectedCity" @bind:after="RebuildEventLists">
                <option value="">Todas</option>
                @foreach (var city in availableCities)
                {
                    <option value="@city">@city</option>
                }
            </select>
        </div>
        <div class="field">
            <label for="filtroDia">Dia da semana</label>
            <select id="filtroDia" class="field__input" @bind="selectedDayOfWeek" @bind:after="RebuildEventLists">
                <option value="">Todos</option>
                @foreach (var day in availableDaysOfWeek)
                {
                    <option value="@day">@day</option>
                }
            </select>
        </div>
        <div class="field">
            <label for="filtroGenero">Geek</label>
            <select id="filtroGenero" class="field__input" @bind="selectedGenre" @bind:after="RebuildEventLists">
                <option value="">Todos</option>
                @foreach (var genre in availableGenres)
                {
                    <option value="@genre">@genre</option>
                }
            </select>
        </div>
        <div class="field field--action">
            <button class="filter-clear-button" type="button" @onclick="ResetFilters">Limpar filtros</button>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="status-box status-box--error">@errorMessage</div>
    }
    else if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="status-box status-box--success">@statusMessage</div>
    }
    else if (isLoading)
    {
        <div class="status-box">Carregando a agenda geek...</div>
    }
    else if (filteredEvents.Count == 0)
    {
        <div class="status-box">Nenhum evento encontrado para os filtros selecionados.</div>
    }
    else
    {
        <section class="events-grid">
            @foreach (var item in filteredEvents)
            {
                <article class="event-card @GetTheme(item)"
                         tabindex="0"
                         role="link"
                         @onclick="() => OpenEvent(item.Id)"
                         @onkeydown="args => HandleEventCardKeyDown(args, item.Id)">
                    @if (!string.IsNullOrWhiteSpace(item.ImagemUrl))
                    {
                        <img class="event-card__image" src="@item.ImagemUrl" alt="@item.Nome" />
                    }
                    <div class="event-card__glow"></div>
                    <div class="event-card__content">
                        <div class="event-card__meta">
                            <span class="pill">@GetCategory(item)</span>
                            <span class="pill pill--muted">@item.CapacidadeTotal lugares</span>
                        </div>

                        <h2>@item.Nome</h2>
                        <p class="event-card__artist">@item.Artista</p>
                        <p class="event-card__location">@item.LocalEvento, @item.CidadeEvento</p>
                        <p class="event-card__date">@item.DataEvento.ToString("dd/MM/yyyy 'as' HH:mm")</p>
                        <div class="event-card__actions">
                            <button class="buy-button" type="button" @onclick:stopPropagation="true" @onclick="() => OpenEvent(item.Id)">Ver ingressos</button>
                        </div>
                    </div>
                </article>
            }
        </section>
    }
</div>

@code {
    private readonly List<EventViewModel> events = new();
    private readonly List<EventViewModel> featuredEvents = new();
    private readonly List<EventViewModel> filteredEvents = new();
    private readonly List<string> availableCities = new();
    private readonly List<string> availableGenres = new();
    private readonly List<string> availableDaysOfWeek = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string statusMessage = string.Empty;
    private string selectedCity = string.Empty;
    private string selectedDayOfWeek = string.Empty;
    private string selectedGenre = string.Empty;
    private int featuredIndex;
    private Timer? featuredTimer;

    protected override async Task OnInitializedAsync()
    {
        EventSearch.OnChange += HandleSearchChanged;

        try
        {
            events.Clear();
            events.AddRange(await ApiClient.GetEventsAsync());
            RebuildEventLists();
        }
        catch
        {
            errorMessage = "Não foi possível carregar a agenda neste momento. Tente novamente em instantes.";
        }
        finally
        {
            isLoading = false;
            StartFeaturedTimer();
        }
    }

    private void ResetFilters()
    {
        selectedCity = string.Empty;
        selectedDayOfWeek = string.Empty;
        selectedGenre = string.Empty;
        EventSearch.Clear();
        RebuildEventLists();
    }

    private void OpenEvent(int eventId)
    {
        Navigation.NavigateTo($"/eventos/{eventId}");
    }

    private void HandleEventCardKeyDown(KeyboardEventArgs args, int eventId)
    {
        if (args.Key is "Enter" or " ")
            OpenEvent(eventId);
    }

    private void HandleSearchChanged()
    {
        RebuildEventLists();
        InvokeAsync(StateHasChanged);
    }

    private void RebuildEventLists()
    {
        featuredEvents.Clear();
        featuredEvents.AddRange(events
            .Where(item => item.EhDestaque)
            .OrderBy(item => item.DataEvento));

        filteredEvents.Clear();
        filteredEvents.AddRange(events
            .Where(MatchesSearch)
            .Where(item => string.IsNullOrWhiteSpace(selectedCity) || item.CidadeEvento == selectedCity)
            .Where(item => string.IsNullOrWhiteSpace(selectedDayOfWeek) || GetDayLabel(item.DataEvento.DayOfWeek) == selectedDayOfWeek)
            .Where(item => string.IsNullOrWhiteSpace(selectedGenre) || item.GeneroMusical == selectedGenre));

        availableCities.Clear();
        availableCities.AddRange(events
            .Select(item => item.CidadeEvento)
            .Where(item => !string.IsNullOrWhiteSpace(item))
            .Distinct()
            .OrderBy(item => item));

        availableGenres.Clear();
        availableGenres.AddRange(events
            .Select(item => item.GeneroMusical)
            .Where(item => !string.IsNullOrWhiteSpace(item))
            .Distinct()
            .OrderBy(item => item));

        availableDaysOfWeek.Clear();
        availableDaysOfWeek.AddRange(events
            .Select(item => GetDayLabel(item.DataEvento.DayOfWeek))
            .Distinct());

        if (featuredIndex >= featuredEvents.Count)
            featuredIndex = 0;
    }

    private bool MatchesSearch(EventViewModel item)
    {
        var searchText = EventSearch.SearchText.Trim();
        if (string.IsNullOrWhiteSpace(searchText))
            return true;

        return ContainsSearch(item.Nome, searchText) ||
               ContainsSearch(item.Artista, searchText) ||
               ContainsSearch(item.LocalEvento, searchText) ||
               ContainsSearch(item.CidadeEvento, searchText) ||
               ContainsSearch(item.GeneroMusical, searchText);
    }

    private static bool ContainsSearch(string? value, string searchText)
    {
        return !string.IsNullOrWhiteSpace(value) &&
               value.Contains(searchText, StringComparison.CurrentCultureIgnoreCase);
    }

    private IReadOnlyList<EventViewModel> GetVisibleFeaturedItems()
    {
        var items = featuredEvents;
        if (items.Count <= 2)
            return items;

        return Enumerable.Range(0, 2)
            .Select(offset => items[(featuredIndex + offset) % items.Count])
            .ToList();
    }

    private void PreviousFeatured()
    {
        var count = featuredEvents.Count;
        if (count <= 1)
            return;

        featuredIndex = (featuredIndex - 1 + count) % count;
    }

    private void NextFeatured()
    {
        var count = featuredEvents.Count;
        if (count <= 1)
            return;

        featuredIndex = (featuredIndex + 1) % count;
    }

    private void StartFeaturedTimer()
    {
        if (featuredEvents.Count <= 2)
            return;

        featuredTimer?.Dispose();
        featuredTimer = new Timer(_ =>
        {
            InvokeAsync(() =>
            {
                NextFeatured();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(4), TimeSpan.FromSeconds(4));
    }

    private static string GetCategory(EventViewModel item)
    {
        var name = item.GeneroMusical.ToLowerInvariant();

        if (name.Contains("anime"))
            return "Anime";
        if (name.Contains("game"))
            return "Games";
        if (name.Contains("cosplay"))
            return "Cosplay";
        if (name.Contains("card"))
            return "Card Game";
        if (name.Contains("k-pop") || name.Contains("kpop"))
            return "K-pop";

        return "Geek";
    }

    private static string GetTheme(EventViewModel item)
    {
        var name = item.GeneroMusical.ToLowerInvariant();

        if (name.Contains("anime"))
            return "event-card--sunset";
        if (name.Contains("game"))
            return "event-card--night";
        if (name.Contains("cosplay") || name.Contains("k-pop") || name.Contains("kpop"))
            return "event-card--neon";
        if (name.Contains("card"))
            return "event-card--gold";

        return string.Empty;
    }

    private static string GetDayLabel(DayOfWeek dayOfWeek)
    {
        return dayOfWeek switch
        {
            DayOfWeek.Sunday => "Domingo",
            DayOfWeek.Monday => "Segunda-feira",
            DayOfWeek.Tuesday => "Terça-feira",
            DayOfWeek.Wednesday => "Quarta-feira",
            DayOfWeek.Thursday => "Quinta-feira",
            DayOfWeek.Friday => "Sexta-feira",
            DayOfWeek.Saturday => "Sábado",
            _ => string.Empty
        };
    }

    public void Dispose()
    {
        EventSearch.OnChange -= HandleSearchChanged;
        featuredTimer?.Dispose();
    }
}
