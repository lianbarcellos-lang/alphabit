@page "/eventos"
@inject AlphabitApiClient ApiClient
@inject AuthOverlayState AuthOverlay
@inject CartState Cart
@inject UserSessionState Session
@inject NavigationManager Navigation

<PageTitle>Eventos</PageTitle>

<div class="events-shell">
    <section class="events-hero">
        <div class="events-hero__copy">
            <span class="eyebrow">Agenda geek em destaque</span>
            <h1>Encontre eventos por categoria, cidade, data e atração.</h1>
            <p>
                @if (Session.CurrentUser is not null)
                {
                    <span>Bem-vindo, <strong>@Session.CurrentUser.Nome</strong>. Explore convenções, campeonatos e experiências para reservar seu lugar.</span>
                }
                else
                {
                    <span>Confira eventos recomendados, veja os destaques da agenda geek e encontre a melhor opção para você.</span>
                }
            </p>

            <div class="events-hero__search">
                <div>
                    <span>Busca rápida</span>
                    <strong>Anime, games, cosplay, card games e cultura pop</strong>
                </div>
                <button class="search-button" type="button" @onclick="ResetFilters">Limpar filtros</button>
            </div>
        </div>

        <div class="events-hero__aside">
            <div class="events-hero__panel">
                <strong>@events.Count</strong>
                <span>eventos publicados</span>
            </div>
            <div class="events-hero__panel">
                <strong>@availableCities.Count</strong>
                <span>cidades com agenda ativa</span>
            </div>
        </div>
    </section>

    <section class="events-highlight">
        <article class="highlight-panel">
            <span class="eyebrow">Escolha melhor</span>
            <strong>Cards grandes, informação clara e caminho rápido para ver ingressos.</strong>
        </article>
        <article class="highlight-panel highlight-panel--dark">
            <span class="eyebrow">Próximo passo</span>
            <strong>Clique em um evento para abrir os detalhes e escolher seu ingresso.</strong>
        </article>
    </section>

    <section class="events-filters">
        <div class="field">
            <label for="filtroCidade">Cidade</label>
            <select id="filtroCidade" class="field__input" @bind="selectedCity">
                <option value="">Todas</option>
                @foreach (var city in availableCities)
                {
                    <option value="@city">@city</option>
                }
            </select>
        </div>
        <div class="field">
            <label for="filtroDia">Dia da semana</label>
            <select id="filtroDia" class="field__input" @bind="selectedDayOfWeek">
                <option value="">Todos</option>
                @foreach (var day in availableDaysOfWeek)
                {
                    <option value="@day">@day</option>
                }
            </select>
        </div>
        <div class="field">
            <label for="filtroArtista">Atração</label>
            <select id="filtroArtista" class="field__input" @bind="selectedArtist">
                <option value="">Todos</option>
                @foreach (var artist in availableArtists)
                {
                    <option value="@artist">@artist</option>
                }
            </select>
        </div>
        <div class="field">
            <label for="filtroGenero">Categoria geek</label>
            <select id="filtroGenero" class="field__input" @bind="selectedGenre">
                <option value="">Todos</option>
                @foreach (var genre in availableGenres)
                {
                    <option value="@genre">@genre</option>
                }
            </select>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="status-box status-box--error">@errorMessage</div>
    }
    else if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="status-box status-box--success">@statusMessage</div>
    }
    else if (isLoading)
    {
        <div class="status-box">Carregando a agenda geek...</div>
    }
    else if (filteredEvents.Count == 0)
    {
        <div class="status-box">Nenhum evento encontrado para os filtros selecionados.</div>
    }
    else
    {
        <section class="events-grid">
            @foreach (var item in filteredEvents)
            {
                <article class="event-card @GetTheme(item)">
                    @if (!string.IsNullOrWhiteSpace(item.ImagemUrl))
                    {
                        <img class="event-card__image" src="@item.ImagemUrl" alt="@item.Nome" />
                    }
                    <div class="event-card__glow"></div>
                    <div class="event-card__content">
                        <div class="event-card__meta">
                            <span class="pill">@GetCategory(item)</span>
                            <span class="pill pill--muted">@item.CapacidadeTotal lugares</span>
                        </div>

                        <h2>@item.Nome</h2>
                        <p class="event-card__artist">@item.Artista</p>
                        <p class="event-card__location">@item.LocalEvento, @item.CidadeEvento</p>
                        <p class="event-card__date">@item.DataEvento.ToString("dd/MM/yyyy 'as' HH:mm")</p>
                        <p class="event-card__description">@GetDescription(item)</p>
                        <div class="event-card__pricing">
                            <strong>R$ @item.PrecoPadrao.ToString("0.00")</strong>
                            <span>@FormatRating(item)</span>
                        </div>
                        <div class="event-card__actions">
                            <button class="ghost-button" type="button" @onclick='() => Navigation.NavigateTo($"/eventos/{item.Id}")'>Ver ingressos</button>
                            <button class="buy-button" type="button" @onclick='() => GoToSeatSelection(item.Id)'>Comprar agora</button>
                        </div>
                    </div>
                </article>
            }
        </section>
    }
</div>

@code {
    private readonly List<EventViewModel> events = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string statusMessage = string.Empty;
    private string selectedCity = string.Empty;
    private string selectedDayOfWeek = string.Empty;
    private string selectedArtist = string.Empty;
    private string selectedGenre = string.Empty;

    private IReadOnlyList<EventViewModel> filteredEvents => events
        .Where(item => string.IsNullOrWhiteSpace(selectedCity) || item.CidadeEvento == selectedCity)
        .Where(item => string.IsNullOrWhiteSpace(selectedDayOfWeek) || GetDayLabel(item.DataEvento.DayOfWeek) == selectedDayOfWeek)
        .Where(item => string.IsNullOrWhiteSpace(selectedArtist) || item.Artista == selectedArtist)
        .Where(item => string.IsNullOrWhiteSpace(selectedGenre) || item.GeneroMusical == selectedGenre)
        .ToList();

    private IReadOnlyList<string> availableCities => events.Select(item => item.CidadeEvento).Where(item => !string.IsNullOrWhiteSpace(item)).Distinct().OrderBy(item => item).ToList();
    private IReadOnlyList<string> availableArtists => events.Select(item => item.Artista).Where(item => !string.IsNullOrWhiteSpace(item)).Distinct().OrderBy(item => item).ToList();
    private IReadOnlyList<string> availableGenres => events.Select(item => item.GeneroMusical).Where(item => !string.IsNullOrWhiteSpace(item)).Distinct().OrderBy(item => item).ToList();
    private IReadOnlyList<string> availableDaysOfWeek => events.Select(item => GetDayLabel(item.DataEvento.DayOfWeek)).Distinct().ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            events.Clear();
            events.AddRange(await ApiClient.GetEventsAsync());
        }
        catch
        {
            errorMessage = "Não foi possível carregar a agenda neste momento. Tente novamente em instantes.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoToSeatSelection(int eventId)
    {
        if (Session.CurrentUser is null)
        {
            AuthOverlay.OpenLogin();
            return;
        }

        Navigation.NavigateTo($"/eventos/{eventId}/assentos");
    }

    private void ResetFilters()
    {
        selectedCity = string.Empty;
        selectedDayOfWeek = string.Empty;
        selectedArtist = string.Empty;
        selectedGenre = string.Empty;
    }

    private static string GetCategory(EventViewModel item)
    {
        var name = item.GeneroMusical.ToLowerInvariant();

        if (name.Contains("anime"))
            return "Anime";
        if (name.Contains("game"))
            return "Games";
        if (name.Contains("cosplay"))
            return "Cosplay";
        if (name.Contains("card"))
            return "Card Game";
        if (name.Contains("k-pop") || name.Contains("kpop"))
            return "K-pop";

        return "Geek";
    }

    private static string GetTheme(EventViewModel item)
    {
        var name = item.GeneroMusical.ToLowerInvariant();

        if (name.Contains("anime"))
            return "event-card--sunset";
        if (name.Contains("game"))
            return "event-card--night";
        if (name.Contains("cosplay") || name.Contains("k-pop") || name.Contains("kpop"))
            return "event-card--neon";
        if (name.Contains("card"))
            return "event-card--gold";

        return string.Empty;
    }

    private static string GetDescription(EventViewModel item)
    {
        var name = item.GeneroMusical.ToLowerInvariant();

        if (name.Contains("anime"))
            return "Painéis, lojas temáticas, artistas convidados e uma atmosfera feita para fãs de anime e mangá.";
        if (name.Contains("game"))
            return "Estações de gameplay, torneios, ativações e experiências para quem vive o universo dos jogos.";
        if (name.Contains("cosplay"))
            return "Desfiles, concursos, fotos e encontros para cosplayers e fãs acompanharem de perto.";
        if (name.Contains("card"))
            return "Mesas, campeonatos e comunidades reunidas para partidas competitivas e trocas.";

        return "Uma experiência geek especial para garantir seu lugar com antecedência.";
    }

    private static string FormatRating(EventViewModel item)
    {
        return item.TotalAvaliacoes == 0
            ? "Sem avaliações"
            : $"{item.MediaAvaliacoes:0.0}/5 ({item.TotalAvaliacoes})";
    }

    private static string GetDayLabel(DayOfWeek dayOfWeek)
    {
        return dayOfWeek switch
        {
            DayOfWeek.Sunday => "Domingo",
            DayOfWeek.Monday => "Segunda-feira",
            DayOfWeek.Tuesday => "Terça-feira",
            DayOfWeek.Wednesday => "Quarta-feira",
            DayOfWeek.Thursday => "Quinta-feira",
            DayOfWeek.Friday => "Sexta-feira",
            DayOfWeek.Saturday => "Sábado",
            _ => string.Empty
        };
    }
}
