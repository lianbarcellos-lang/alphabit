    private async Task UpdateStandsBatch(
        IReadOnlyList<StandSpaceViewModel> standsToUpdate,
        Func<StandSpaceViewModel, StandAllocationRequest> requestFactory,
        string successMessage,
        string? codeToSelect)
    {
        if (standsToUpdate.Count == 0 || string.IsNullOrWhiteSpace(Session.AdminToken))
            return;

        isBusy = true;
        isError = false;
        statusMessage = string.Empty;

        try
        {
            foreach (var stand in standsToUpdate)
            {
                var result = await ApiClient.UpdateStandAllocationAsync(
                    selectedStandEventId,
                    stand.Id,
                    requestFactory(stand),
                    Session.AdminToken);

                if (!result.Success)
                {
                    isError = true;
                    statusMessage = result.Message;
                    return;
                }
            }

            statusMessage = successMessage;
            await LoadEventStands();

            var selected = string.IsNullOrWhiteSpace(codeToSelect)
                ? null
                : eventStands.FirstOrDefault(stand => string.Equals(stand.Codigo, codeToSelect, StringComparison.OrdinalIgnoreCase));

            if (selected is not null)
                SelectStand(selected);
        }
        catch
        {
            isError = true;
            statusMessage = "Não foi possível atualizar os stands agora.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private static StandAllocationRequest BuildStandUpdateRequest(StandSpaceViewModel stand, string? setor = null)
    {
        return new StandAllocationRequest
        {
            Reservado = stand.Reservado,
            Setor = setor ?? stand.Setor,
            Codigo = stand.Codigo,
            TipoArea = string.IsNullOrWhiteSpace(stand.TipoArea) ? "Stand" : stand.TipoArea,
            AreaX = stand.AreaX,
            AreaY = stand.AreaY,
            AreaLargura = stand.AreaLargura <= 0 ? 12 : stand.AreaLargura,
            AreaAltura = stand.AreaAltura <= 0 ? 8 : stand.AreaAltura,
            AreaMetrosQuadrados = stand.AreaMetrosQuadrados,
            PrecoPorMetroQuadrado = stand.PrecoPorMetroQuadrado,
            PrecoFixo = stand.PrecoFixo,
            NomeOcupante = stand.NomeOcupante,
            TipoOcupante = stand.TipoOcupante,
            Descricao = stand.Descricao
        };
    }

    private async Task SaveStandAllocation()
    {
        if (string.IsNullOrWhiteSpace(Session.AdminToken) || selectedStand is null)
            return;

        var standId = selectedStand.Id;
        var editedCode = standEditCode.Trim();
        var editedSector = NormalizeStandSector(standEditSector);

        if (string.IsNullOrWhiteSpace(editedCode))
        {
            isError = true;
            statusMessage = "Informe o código do stand.";
            return;
        }

        var duplicateCode = eventStands.Any(stand =>
            stand.Id != standId &&
            string.Equals(stand.Codigo, editedCode, StringComparison.OrdinalIgnoreCase));

        if (duplicateCode)
        {
            isError = true;
            statusMessage = "Já existe outro stand com este código.";
            return;
        }

        var occupantName = standAllocationModel.NomeOcupante.Trim();
        if (HasDuplicateStandName(occupantName, standId))
        {
            isError = true;
            statusMessage = "Já existe um stand cadastrado com esse nome.";
            return;
        }

        statusMessage = string.Empty;
        isError = false;
        isBusy = true;

        try
        {
            var selected = selectedStand;
            if (selected is null)
                return;

            var updateRequest = new StandAllocationRequest
            {
                Reservado = !string.IsNullOrWhiteSpace(occupantName),
                Setor = editedSector,
                Codigo = editedCode,
                TipoArea = "Stand",
                AreaX = standAllocationModel.AreaX <= 0 ? selected.AreaX : standAllocationModel.AreaX,
                AreaY = standAllocationModel.AreaY <= 0 ? selected.AreaY : standAllocationModel.AreaY,
                AreaLargura = standAllocationModel.AreaLargura <= 0 ? selected.AreaLargura : standAllocationModel.AreaLargura,
                AreaAltura = standAllocationModel.AreaAltura <= 0 ? selected.AreaAltura : standAllocationModel.AreaAltura,
                AreaMetrosQuadrados = Math.Max(0, standAllocationModel.AreaMetrosQuadrados),
                PrecoPorMetroQuadrado = Math.Max(0, standAllocationModel.PrecoPorMetroQuadrado),
                PrecoFixo = Math.Max(0, standAllocationModel.PrecoFixo),
                NomeOcupante = occupantName,
                TipoOcupante = standAllocationModel.TipoOcupante.Trim(),
                Descricao = standAllocationModel.Descricao.Trim()
            };

            var result = await ApiClient.UpdateStandAllocationAsync(selectedStandEventId, standId, updateRequest, Session.AdminToken);
            isError = !result.Success;
            statusMessage = result.Message;

            if (result.Success)
            {
                await LoadEventStands();
                var updatedStand = eventStands.FirstOrDefault(stand => stand.Id == standId)
                    ?? eventStands.FirstOrDefault(stand => string.Equals(stand.Codigo, editedCode, StringComparison.OrdinalIgnoreCase));

                if (updatedStand is not null)
                    SelectStand(updatedStand);
            }
        }
        catch
        {
            isError = true;
            statusMessage = "Não foi possível atualizar o stand agora.";
        }
        finally
        {
            isBusy = false;
        }
    }

