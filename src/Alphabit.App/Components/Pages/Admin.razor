@page "/admin"
@implements IAsyncDisposable
@inject AlphabitApiClient ApiClient
@inject UserSessionState Session
@inject NavigationManager Navigation
@inject AuthOverlayState AuthOverlay
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.WebUtilities

<PageTitle>Área ADM</PageTitle>

@if (!Session.IsAdmin || string.IsNullOrWhiteSpace(Session.AdminToken))
{
    <div class="admin-shell">
        <div class="status-box status-box--error">
            Acesso restrito. Entre como administrador para gerenciar a agenda GeekTop.
        </div>
        @if (checkinCodeLoadedFromUrl)
        {
            <div class="admin-note">
                <strong>QR Code lido com sucesso.</strong>
                <span>Entre como administrador para validar a reserva @checkinQrCode.</span>
            </div>
            <button class="secondary-button" type="button" @onclick="OpenAdminLogin">Entrar como administrador</button>
        }
        <button class="ghost-button" @onclick='() => Navigation.NavigateTo("/")'>Voltar para o início</button>
    </div>
}
else
{
    <div class="admin-shell">
        <section class="admin-hero">
            <div class="admin-hero__copy">
                <span class="eyebrow">Painel GeekTop</span>
                <h1>Gerencie eventos, imagens e cupons da temporada</h1>
                <p>Use esta área para publicar convenções, torneios e experiências geek na agenda comercial do site.</p>

                <div class="admin-hero__chips">
                    <span>Eventos em destaque</span>
                    <span>Cupons promocionais</span>
                    <span>Atualização rápida</span>
                </div>

                <div class="admin-view-switcher">
                    <button class="@(activeAdminView == "operacao" ? "secondary-button" : "ghost-button")" type="button" @onclick='() => SetAdminView("operacao")'>Controle de ingressos</button>
                    <button class="@(activeAdminView == "vendas" ? "secondary-button" : "ghost-button")" type="button" @onclick='() => SetAdminView("vendas")'>Relatório de vendas</button>
                    <button class="@(activeAdminView == "mapa" ? "secondary-button" : "ghost-button")" type="button" @onclick='() => SetAdminView("mapa")'>Mapa de stands</button>
                </div>
            </div>

            <div class="admin-hero__actions">
                <div class="admin-hero__badge">
                    <strong>@adminEvents.Count</strong>
                    <span>eventos ativos na vitrine</span>
                </div>
                <button class="ghost-button" @onclick="Logout">Sair do ADM</button>
            </div>
        </section>

        @if (activeAdminView == "operacao")
        {
            <section class="admin-stats">
                <article class="admin-stat-card">
                    <span>Eventos ativos</span>
                    <strong>@adminEvents.Count</strong>
                </article>
                <article class="admin-stat-card">
                    <span>Operação</span>
                    <strong>Agenda viva</strong>
                </article>
                <article class="admin-stat-card admin-stat-card--accent">
                    <span>Foco</span>
                    <strong>Controle de ingressos</strong>
                </article>
            </section>
        }

        @if (activeAdminView == "vendas")
        {
        <section class="admin-panel admin-panel--sales">
            <div class="admin-list-header">
                <div>
                    <h2>Radar comercial</h2>
                    <p>Acompanhe as últimas compras, os eventos que mais giram receita e o status do caixa em tempo real.</p>
                </div>
                <button class="ghost-button" @onclick="LoadAdminSalesDashboard" disabled="@isBusy">Atualizar vendas</button>
            </div>

            @if (salesLoading)
            {
                <div class="status-box">Carregando movimentação comercial...</div>
            }
            else if (salesDashboard is null)
            {
                <div class="status-box">Não foi possível carregar o painel de vendas agora.</div>
            }
            else
            {
                <div class="admin-sales-grid">
                    <article class="admin-sales-card">
                        <h3>Eventos mais vendidos</h3>
                        @if (salesDashboard.EventosMaisVendidos.Count == 0)
                        {
                            <p>Ainda não houve compras suficientes para montar um ranking.</p>
                        }
                        else
                        {
                            <div class="admin-sales-list">
                                @foreach (var item in salesDashboard.EventosMaisVendidos)
                                {
                                    <div class="admin-sales-list__row">
                                        <div>
                                            <strong>@item.Evento</strong>
                                            <span>@item.IngressosVendidos ingresso(s)</span>
                                        </div>
                                        <strong>R$ @item.ValorArrecadado.ToString("0.00")</strong>
                                    </div>
                                }
                            </div>
                        }
                    </article>

                    <article class="admin-sales-card">
                        <h3>Últimas compras realizadas</h3>
                        @if (salesDashboard.UltimasCompras.Count == 0)
                        {
                            <p>Nenhuma compra registrada ainda.</p>
                        }
                        else
                        {
                            <div class="admin-sales-list">
                                @foreach (var item in salesDashboard.UltimasCompras)
                                {
                                    <div class="admin-sales-list__row">
                                        <div>
                                            <strong>@item.Evento</strong>
                                            <span>@item.DataCompra.ToString("dd/MM/yyyy HH:mm") • @GetPaymentMethodLabel(item.FormaPagamento) • @GetPaymentStatusLabel(item.StatusPagamento)</span>
                                        </div>
                                        <strong>R$ @item.ValorPago.ToString("0.00")</strong>
                                    </div>
                                }
                            </div>
                        }
                    </article>

                    <article class="admin-sales-card admin-sales-card--metrics">
                        <h3>Operação da temporada</h3>
                        <div class="admin-metric-list">
                            <div>
                                <span>Eventos cadastrados</span>
                                <strong>@salesDashboard.TotalEventos</strong>
                            </div>
                            <div>
                                <span>Capacidade total</span>
                                <strong>@salesDashboard.CapacidadeTotal</strong>
                            </div>
                            <div>
                                <span>Reservas pagas</span>
                                <strong>@salesDashboard.ReservasPagas</strong>
                            </div>
                            <div>
                                <span>Reservas pendentes</span>
                                <strong>@salesDashboard.ReservasPendentesPagamento</strong>
                            </div>
                            <div>
                                <span>Reservas canceladas</span>
                                <strong>@salesDashboard.ReservasCanceladas</strong>
                            </div>
                            <div>
                                <span>Cupons usados</span>
                                <strong>@salesDashboard.CuponsUtilizados</strong>
                            </div>
                            <div>
                                <span>Pagamentos Pix</span>
                                <strong>@salesDashboard.PagamentosPix</strong>
                            </div>
                            <div>
                                <span>Pagamentos Cartão</span>
                                <strong>@salesDashboard.PagamentosCartao</strong>
                            </div>
                            <div>
                                <span>Pagamentos Boleto</span>
                                <strong>@salesDashboard.PagamentosBoleto</strong>
                            </div>
                        </div>
                    </article>

                    <article class="admin-sales-card admin-sales-card--reviews">
                        <h3>Últimas avaliações</h3>
                        @if (salesDashboard.UltimasAvaliacoes.Count == 0)
                        {
                            <p>Ainda não há avaliações para moderar.</p>
                        }
                        else
                        {
                            <div class="admin-review-list">
                                @foreach (var review in salesDashboard.UltimasAvaliacoes)
                                {
                                    <div class="admin-review-item">
                                        <div>
                                            <strong>@review.Evento</strong>
                                            <span>@review.UsuarioNome - @review.Nota/5 - @review.CriadoEm.ToString("dd/MM/yyyy HH:mm")</span>
                                            @if (!string.IsNullOrWhiteSpace(review.Comentario))
                                            {
                                                <p>@review.Comentario</p>
                                            }
                                        </div>
                                        <button class="ghost-button"
                                                type="button"
                                                disabled="@isBusy"
                                                @onclick="() => HandleDeleteReview(review.Id)">
                                            Remover
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                    </article>
                </div>

                @if (salesDashboard.Compras.Count == 0)
                {
                    <div class="status-box">Ainda não existem compras para exibir na tabela comercial.</div>
                }
                else
                {
                    <div class="admin-sales-table-wrap">
                        <table class="admin-sales-table">
                            <thead>
                                <tr>
                                    <th>Cliente</th>
                                    <th>Evento</th>
                                    <th>Data da compra</th>
                                    <th>Forma de pagamento</th>
                                    <th>Status</th>
                                    <th>Valor</th>
                                    <th>Qtd</th>
                                    <th>Setor / cadeira / lote</th>
                                    <th>Pedido</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in salesDashboard.Compras)
                                {
                                    <tr>
                                        <td>
                                            <strong>@item.Cliente</strong>
                                            <span>@item.ClienteEmail</span>
                                        </td>
                                        <td>@item.Evento</td>
                                        <td>@item.DataCompra.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@GetPaymentMethodLabel(item.FormaPagamento)</td>
                                        <td>
                                            <span class="admin-status-pill @GetPaymentStatusClass(item.StatusPagamento)">
                                                @GetPaymentStatusLabel(item.StatusPagamento)
                                            </span>
                                        </td>
                                        <td>R$ @item.ValorPago.ToString("0.00")</td>
                                        <td>@item.QuantidadeIngressos</td>
                                        <td>@item.SetorCadeiraLote</td>
                                        <td>@item.CodigoPedido</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </section>
        }

        @if (activeAdminView == "mapa")
        {
            <section class="admin-panel admin-stand-panel">
                <div class="admin-list-header">
                    <div>
                        <span class="admin-panel__pill">Mapa de stands</span>
                        <h2>Alocação de expositores</h2>
                        <p>Selecione um evento, clique em um espaço do mapa e reserve para empresas, marcas ou atrações.</p>
                    </div>
                    <div class="admin-list-header__actions">
                        <button class="ghost-button" type="button" @onclick="LoadEventStands" disabled="@isBusy">Atualizar mapa</button>
                    </div>
                </div>

                <div class="admin-form__grid">
                    <div class="field">
                        <label for="standEvent">Evento</label>
                        <select id="standEvent" class="field__input" value="@selectedStandEventId" @onchange="HandleStandEventChanged">
                            @foreach (var item in adminEvents)
                            {
                                <option value="@item.Id">@item.Nome</option>
                            }
                        </select>
                    </div>
                    <div class="field">
                        <label>Espaço selecionado</label>
                        <div class="admin-note">
                            <strong>@(selectedStand is null ? "Nenhum stand selecionado" : $"{selectedStand.Codigo} - {selectedStand.Setor}")</strong>
                            <span>@(selectedStand is null ? "Arraste um stand para posicionar ou cadastre um novo espaço." : selectedStand.Reservado ? selectedStand.NomeOcupante : "Disponível para reserva")</span>
                        </div>
                    </div>
                </div>

                <div class="admin-map-upload">
                    <div>
                        <h3>Planta em branco do evento</h3>
                        <p>Envie a imagem da planta e arraste os stands para marcar a localização de cada barraca.</p>
                    </div>
                    <div class="admin-map-upload__controls">
                        <InputFile OnChange="HandleStandMapImageSelected" accept="image/*" />
                        <InputText class="field__input" @bind-Value="standMapImageUrl" placeholder="Ou cole uma URL da planta" />
                        <button class="ghost-button" type="button" @onclick="SaveStandMapImageFromInput" disabled="@isBusy">Salvar planta</button>
                    </div>
                </div>

                @if (selectedStandEventId <= 0)
                {
                    <div class="status-box">Selecione um evento para organizar as linhas e os stands.</div>
                }
                else
                {
                    <div class="admin-stand-layout">
                        <div class="admin-stand-map-area">
                            @if (HasStandMapImage)
                            {
                                <div id="@StandMapDropElementId"
                                     class="admin-stand-image-map"
                                     @ondragover:preventDefault="true"
                                     @ondrop="DropStandOnMap">
                                    <img src="@standMapImageUrl" alt="Planta do evento" />
                                    @foreach (var stand in eventStands)
                                    {
                                        <button class="admin-stand-pin @(stand.Id == selectedStandId ? "admin-stand-pin--selected" : null) @(stand.Reservado ? "admin-stand-pin--reserved" : null)"
                                                @key="stand.Id"
                                                data-stand-id="@stand.Id"
                                                style="@BuildStandPinStyle(stand)"
                                                type="button"
                                                draggable="false"
                                                title="@BuildStandPinTitle(stand)"
                                                @onclick="() => SelectStand(stand)">
                                            <strong>@stand.Codigo</strong>
                                        </button>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="admin-stand-map" style="@BuildAdminStandMapStyle()">
                                    @foreach (var stand in eventStands)
                                    {
                                        <button class="admin-stand-block @(stand.Id == selectedStandId ? "admin-stand-block--selected" : null) @(stand.Reservado ? "admin-stand-block--reserved" : null)"
                                                @key="stand.Id"
                                                style="@BuildAdminStandStyle(stand)"
                                                type="button"
                                                draggable="true"
                                                @ondragstart="() => BeginStandDrag(stand.Id)"
                                                @onclick="() => SelectStand(stand)">
                                            <span>@stand.Codigo</span>
                                            <strong>@(stand.Reservado ? stand.NomeOcupante : "Livre")</strong>
                                            <small>@stand.Setor</small>
                                        </button>
                                    }
                                </div>
                            }

                            <div class="admin-stand-layout-tools">
                                <div>
                                    <strong>Organização automática</strong>
                                    <span>Escolha uma grade inicial. Depois você pode arrastar os stands livremente.</span>
                                </div>
                                <div class="admin-stand-grid-options">
                                    @foreach (var option in standLayoutOptions)
                                    {
                                        <button class="ghost-button"
                                                type="button"
                                                disabled="@(isBusy || eventStands.Count == 0 || eventStands.Count > option.Capacity)"
                                                title="@GetStandLayoutOptionTitle(option)"
                                                @onclick="() => ApplyStandLayoutGrid(option.Size)">
                                            @option.Label
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="admin-stand-editor">
                            <h3>Reservar espaço</h3>
                            @if (selectedStand is null)
                            {
                                <p>Cadastre um stand e depois arraste-o para a posição desejada na planta.</p>
                                <div class="field">
                                    <label for="novoStandCodigo">Código do stand</label>
                                    <InputText id="novoStandCodigo" class="field__input" @bind-Value="standEditCode" placeholder="Ex.: A-01" />
                                </div>
                                <div class="field">
                                    <label for="novoStandLinha">Linha</label>
                                    <select id="novoStandLinha" class="field__input" @bind="standEditSector">
                                        @foreach (var sectorName in GetStandSectorNames())
                                        {
                                            <option value="@sectorName">@sectorName</option>
                                        }
                                    </select>
                                </div>
                                <div class="field">
                                    <label for="novoStandNome">Empresa ou atração</label>
                                    <InputText id="novoStandNome" class="field__input" @bind-Value="standAllocationModel.NomeOcupante" placeholder="LG, Samsung, Ubisoft..." />
                                </div>
                                <div class="field">
                                    <label for="novoStandTipo">Tipo</label>
                                    <InputText id="novoStandTipo" class="field__input" @bind-Value="standAllocationModel.TipoOcupante" placeholder="Expositora, arena, loja..." />
                                </div>
                                <div class="field">
                                    <label for="novoStandDescricao">Descrição curta</label>
                                    <InputTextArea id="novoStandDescricao" class="field__input" @bind-Value="standAllocationModel.Descricao" />
                                </div>
                                <button class="secondary-button" type="button" @onclick="CreateStand" disabled="@isBusy">Cadastrar stand</button>
                            }
                            else
                            {
                                <div class="admin-stand-editor__top">
                                    <p>Editando <strong>@selectedStand.Codigo</strong>. Use "Novo stand" para cadastrar outro espaço sem alterar este.</p>
                                    <button class="ghost-button" type="button" @onclick="PrepareNewStandForm" disabled="@isBusy">Novo stand</button>
                                </div>
                                <div class="field">
                                    <label for="standCodigo">Código do stand</label>
                                    <InputText id="standCodigo" class="field__input" @bind-Value="standEditCode" placeholder="Ex.: AZ-01" />
                                </div>
                                <div class="field">
                                    <label for="standLinha">Linha</label>
                                    <select id="standLinha" class="field__input" @bind="standEditSector">
                                        @foreach (var sectorName in GetStandSectorNames())
                                        {
                                            <option value="@sectorName">@sectorName</option>
                                        }
                                    </select>
                                </div>
                                <div class="field">
                                    <label for="standNome">Empresa ou atração</label>
                                    <InputText id="standNome" class="field__input" @bind-Value="standAllocationModel.NomeOcupante" placeholder="LG, Samsung, Ubisoft..." />
                                </div>
                                <div class="field">
                                    <label for="standTipo">Tipo</label>
                                    <InputText id="standTipo" class="field__input" @bind-Value="standAllocationModel.TipoOcupante" placeholder="Expositora, arena, loja..." />
                                </div>
                                <div class="field">
                                    <label for="standDescricao">Descrição curta</label>
                                    <InputTextArea id="standDescricao" class="field__input" @bind-Value="standAllocationModel.Descricao" />
                                </div>

                                <div class="admin-event-card__actions">
                                    <button class="secondary-button" type="button" @onclick="SaveStandAllocation" disabled="@isBusy">Salvar stand</button>
                                    <button class="danger-button" type="button" @onclick="ReleaseStand" disabled="@isBusy">Liberar espaço</button>
                                    <button class="danger-button" type="button" @onclick="DeleteSelectedStand" disabled="@isBusy">Apagar stand</button>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="event-stand-sector-list admin-stand-sector-list">
                        <article class="admin-stand-sector-card admin-stand-sector-card--create">
                            <div class="admin-stand-sector-create">
                                <InputText class="field__input" @bind-Value="newStandSectorName" placeholder="Nova linha" />
                                <button class="secondary-button admin-create-line-button" type="button" @onclick="CreateStandSector" disabled="@isBusy">Adicionar</button>
                            </div>
                        </article>
                        @foreach (var sector in GetStandSectorGroups())
                        {
                            <article class="admin-stand-sector-card"
                                     @key="sector.Key"
                                     @ondragover:preventDefault="true"
                                     @ondrop="() => DropStandOnSector(sector.Key)">
                                <div class="admin-stand-sector-card__header">
                                    <input class="field__input"
                                           value="@GetSectorDraftName(sector.Key)"
                                           @oninput="args => SetSectorDraftName(sector.Key, args.Value?.ToString())" />
                                    <div class="admin-stand-sector-card__actions">
                                        <button class="ghost-button" type="button" @onclick="() => RenameSector(sector.Key)" disabled="@isBusy">Salvar nome</button>
                                        <button class="danger-button admin-delete-line-button" type="button" @onclick="() => DeleteStandSector(sector.Key)" disabled="@isBusy">Excluir</button>
                                    </div>
                                </div>
                                <span>@sector.Stands.Count stand(s)</span>
                                <div class="admin-stand-sector-card__allocations">
                                    @if (sector.Stands.Count == 0)
                                    {
                                        <span class="admin-empty-line">Nenhum stand nesta linha.</span>
                                    }
                                    @foreach (var sectorStand in GetVisibleSectorStands(sector.Stands))
                                    {
                                        <div class="admin-stand-sector-allocation @(sectorStand.Id == selectedStandId ? "admin-stand-sector-allocation--selected" : null)"
                                             @key="sectorStand.Id"
                                             draggable="true"
                                             @ondragstart="() => BeginStandDrag(sectorStand.Id)">
                                            <button class="admin-stand-sector-allocation__main" type="button" @onclick="() => SelectStand(sectorStand)">
                                                <strong>@sectorStand.Codigo</strong>
                                                <span>@BuildSectorStandLabel(sectorStand)</span>
                                            </button>
                                            <div class="admin-stand-sector-allocation__actions">
                                                <button type="button" class="ghost-button admin-mini-button" title="Editar stand" @onclick="() => SelectStand(sectorStand)">Editar</button>
                                                <button type="button" class="danger-button admin-mini-button" title="Excluir stand" @onclick="() => DeleteStand(sectorStand)" disabled="@isBusy">×</button>
                                            </div>
                                        </div>
                                    }
                                </div>
                                @if (selectedStand is not null)
                                {
                                    <button class="secondary-button" type="button" @onclick="() => MoveSelectedStandToSector(sector.Key)" disabled="@isBusy">
                                        Mover selecionado para esta linha
                                    </button>
                                }
                            </article>
                        }
                    </div>
                }
            </section>
        }

        @if (activeAdminView == "operacao")
        {
        <div class="admin-grid">
            <section class="admin-panel">
                <div class="admin-panel__head">
                    <span class="admin-panel__pill">Cadastro</span>
                    <h2>Novo evento</h2>
                    <p>Cadastre um evento geek com nome, atração, data, preço e imagem de destaque.</p>
                </div>

                <EditForm Model="@eventModel" OnValidSubmit="HandleCreateEvent" FormName="admin-event-form" class="admin-form">
                    <DataAnnotationsValidator />
                    <div class="admin-form__grid">
                        <div class="field">
                            <label for="eventoNome">Nome do evento</label>
                            <InputText id="eventoNome" class="field__input" @bind-Value="eventModel.Nome" />
                            <ValidationMessage For="() => eventModel.Nome" />
                        </div>
                        <div class="field">
                            <label for="eventoArtista">Atração principal</label>
                            <InputText id="eventoArtista" class="field__input" @bind-Value="eventModel.Artista" />
                            <ValidationMessage For="() => eventModel.Artista" />
                        </div>
                    </div>
                    <div class="admin-form__grid">
                        <div class="field">
                            <label for="eventoLocal">Local do evento</label>
                            <InputText id="eventoLocal" class="field__input" @bind-Value="eventModel.LocalEvento" />
                            <ValidationMessage For="() => eventModel.LocalEvento" />
                        </div>
                        <div class="field">
                            <label for="eventoCidade">Cidade do evento</label>
                            <input id="eventoCidade" type="hidden" @bind="eventModel.CidadeEvento" />
                            <button class="field__input genre-picker-trigger" type="button" @onclick="OpenCreateCityModal">
                                <span>@(string.IsNullOrWhiteSpace(eventModel.CidadeEvento) ? "Selecionar cidade do evento" : eventModel.CidadeEvento)</span>
                                <strong>Selecionar</strong>
                            </button>
                            <ValidationMessage For="() => eventModel.CidadeEvento" />
                        </div>
                    </div>
                    <div class="admin-form__grid admin-form__grid--triple">
                        <div class="field">
                            <label for="eventoGenero">Categoria geek</label>
                            <input id="eventoGenero" type="hidden" @bind="eventModel.GeneroMusical" />
                            <button class="field__input genre-picker-trigger" type="button" @onclick="OpenCreateGenreModal">
                                <span>@(string.IsNullOrWhiteSpace(eventModel.GeneroMusical) ? "Selecionar categoria geek" : eventModel.GeneroMusical)</span>
                                <strong>Selecionar</strong>
                            </button>
                            <ValidationMessage For="() => eventModel.GeneroMusical" />
                        </div>
                        <div class="field">
                            <label for="eventoCapacidade">Capacidade</label>
                            <InputNumber id="eventoCapacidade" class="field__input" @bind-Value="eventModel.CapacidadeTotal" />
                            <ValidationMessage For="() => eventModel.CapacidadeTotal" />
                        </div>
                        <div class="field">
                            <label for="eventoPreco">Preco</label>
                            <InputNumber id="eventoPreco" class="field__input" @bind-Value="eventModel.PrecoPadrao" />
                            <ValidationMessage For="() => eventModel.PrecoPadrao" />
                        </div>
                    </div>
                    <div class="admin-form__grid">
                        <div class="field">
                            <label for="eventoData">Data e hora</label>
                            <InputDate id="eventoData" class="field__input" @bind-Value="eventDateOnly" />
                        </div>
                        <div class="field">
                            <label for="eventoHora">Horario</label>
                            <InputText id="eventoHora" class="field__input" @bind-Value="eventTime" />
                        </div>
                    </div>
                    <div class="field">
                        <label for="eventoImagem">Imagem (URL ou arquivo)</label>
                        <InputText id="eventoImagem" class="field__input" @bind-Value="eventModel.ImagemUrl" />
                        <ValidationMessage For="() => eventModel.ImagemUrl" />
                    </div>
                    <div class="field">
                        <label for="eventoImagemArquivo">Selecionar imagem do computador</label>
                        <InputFile id="eventoImagemArquivo" OnChange="HandleCreateImageSelected" accept="image/*" class="field__file-input" />
