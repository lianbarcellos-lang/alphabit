@page "/admin"
@implements IAsyncDisposable
@inject AlphabitApiClient ApiClient
@inject UserSessionState Session
@inject NavigationManager Navigation
@inject AuthOverlayState AuthOverlay
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.WebUtilities

<PageTitle>Área ADM</PageTitle>

@if (!Session.IsAdmin || string.IsNullOrWhiteSpace(Session.AdminToken))
{
    <div class="admin-shell">
        <div class="status-box status-box--error">
            Acesso restrito. Entre como administrador para gerenciar a agenda GeekTop.
        </div>
        @if (checkinCodeLoadedFromUrl)
        {
            <div class="admin-note">
                <strong>QR Code lido com sucesso.</strong>
                <span>Entre como administrador para validar a reserva @checkinQrCode.</span>
            </div>
            <button class="secondary-button" type="button" @onclick="OpenAdminLogin">Entrar como administrador</button>
        }
        <button class="ghost-button" @onclick='() => Navigation.NavigateTo("/")'>Voltar para o início</button>
    </div>
}
else
{
    <div class="admin-shell">
        <section class="admin-hero">
            <div class="admin-hero__copy">
                <span class="eyebrow">Painel GeekTop</span>
                <h1>Gerencie eventos, imagens e cupons da temporada</h1>
                <p>Use esta área para publicar convenções, torneios e experiências geek na agenda comercial do site.</p>

                <div class="admin-hero__chips">
                    <span>Eventos em destaque</span>
                    <span>Cupons promocionais</span>
                    <span>Atualização rápida</span>
                </div>

                <div class="admin-view-switcher">
                    <button class="@(activeAdminView == "operacao" ? "secondary-button" : "ghost-button")" type="button" @onclick='() => SetAdminView("operacao")'>Controle de ingressos</button>
                    <button class="@(activeAdminView == "vendas" ? "secondary-button" : "ghost-button")" type="button" @onclick='() => SetAdminView("vendas")'>Relatório de vendas</button>
                </div>
            </div>

            <div class="admin-hero__actions">
                <div class="admin-hero__badge">
                    <strong>@adminEvents.Count</strong>
                    <span>eventos ativos na vitrine</span>
                </div>
                <button class="ghost-button" @onclick="Logout">Sair do ADM</button>
            </div>
        </section>

        @if (activeAdminView == "operacao")
        {
            <section class="admin-stats">
                <article class="admin-stat-card">
                    <span>Eventos ativos</span>
                    <strong>@adminEvents.Count</strong>
                </article>
                <article class="admin-stat-card">
                    <span>Operação</span>
                    <strong>Agenda viva</strong>
                </article>
                <article class="admin-stat-card admin-stat-card--accent">
                    <span>Foco</span>
                    <strong>Controle de ingressos</strong>
                </article>
            </section>
        }

        @if (activeAdminView == "vendas")
        {
        <section class="admin-panel admin-panel--sales">
            <div class="admin-list-header">
                <div>
                    <h2>Radar comercial</h2>
                    <p>Acompanhe as últimas compras, os eventos que mais giram receita e o status do caixa em tempo real.</p>
                </div>
                <button class="ghost-button" @onclick="LoadAdminSalesDashboard" disabled="@isBusy">Atualizar vendas</button>
            </div>

            @if (salesLoading)
            {
                <div class="status-box">Carregando movimentação comercial...</div>
            }
            else if (salesDashboard is null)
            {
                <div class="status-box">Não foi possível carregar o painel de vendas agora.</div>
            }
            else
            {
                <div class="admin-sales-grid">
                    <article class="admin-sales-card">
                        <h3>Eventos mais vendidos</h3>
                        @if (salesDashboard.EventosMaisVendidos.Count == 0)
                        {
                            <p>Ainda não houve compras suficientes para montar um ranking.</p>
                        }
                        else
                        {
                            <div class="admin-sales-list">
                                @foreach (var item in salesDashboard.EventosMaisVendidos)
                                {
                                    <div class="admin-sales-list__row">
                                        <div>
                                            <strong>@item.Evento</strong>
                                            <span>@item.IngressosVendidos ingresso(s)</span>
                                        </div>
                                        <strong>R$ @item.ValorArrecadado.ToString("0.00")</strong>
                                    </div>
                                }
                            </div>
                        }
                    </article>

                    <article class="admin-sales-card">
                        <h3>Últimas compras realizadas</h3>
                        @if (salesDashboard.UltimasCompras.Count == 0)
                        {
                            <p>Nenhuma compra registrada ainda.</p>
                        }
                        else
                        {
                            <div class="admin-sales-list">
                                @foreach (var item in salesDashboard.UltimasCompras)
                                {
                                    <div class="admin-sales-list__row">
                                        <div>
                                            <strong>@item.Evento</strong>
                                            <span>@item.DataCompra.ToString("dd/MM/yyyy HH:mm") • @GetPaymentMethodLabel(item.FormaPagamento) • @GetPaymentStatusLabel(item.StatusPagamento)</span>
                                        </div>
                                        <strong>R$ @item.ValorPago.ToString("0.00")</strong>
                                    </div>
                                }
                            </div>
                        }
                    </article>

                    <article class="admin-sales-card admin-sales-card--metrics">
                        <h3>Operação da temporada</h3>
                        <div class="admin-metric-list">
                            <div>
                                <span>Eventos cadastrados</span>
                                <strong>@salesDashboard.TotalEventos</strong>
                            </div>
                            <div>
                                <span>Capacidade total</span>
                                <strong>@salesDashboard.CapacidadeTotal</strong>
                            </div>
                            <div>
                                <span>Reservas pagas</span>
                                <strong>@salesDashboard.ReservasPagas</strong>
                            </div>
                            <div>
                                <span>Reservas pendentes</span>
                                <strong>@salesDashboard.ReservasPendentesPagamento</strong>
                            </div>
                            <div>
                                <span>Reservas canceladas</span>
                                <strong>@salesDashboard.ReservasCanceladas</strong>
                            </div>
                            <div>
                                <span>Cupons usados</span>
                                <strong>@salesDashboard.CuponsUtilizados</strong>
                            </div>
                            <div>
                                <span>Pagamentos Pix</span>
                                <strong>@salesDashboard.PagamentosPix</strong>
                            </div>
                            <div>
                                <span>Pagamentos Cartão</span>
                                <strong>@salesDashboard.PagamentosCartao</strong>
                            </div>
                            <div>
                                <span>Pagamentos Boleto</span>
                                <strong>@salesDashboard.PagamentosBoleto</strong>
                            </div>
                        </div>
                    </article>

                    <article class="admin-sales-card admin-sales-card--reviews">
                        <h3>Últimas avaliações</h3>
                        @if (salesDashboard.UltimasAvaliacoes.Count == 0)
                        {
                            <p>Ainda não há avaliações para moderar.</p>
                        }
                        else
                        {
                            <div class="admin-review-list">
                                @foreach (var review in salesDashboard.UltimasAvaliacoes)
                                {
                                    <div class="admin-review-item">
                                        <div>
                                            <strong>@review.Evento</strong>
                                            <span>@review.UsuarioNome - @review.Nota/5 - @review.CriadoEm.ToString("dd/MM/yyyy HH:mm")</span>
                                            @if (!string.IsNullOrWhiteSpace(review.Comentario))
                                            {
                                                <p>@review.Comentario</p>
                                            }
                                        </div>
                                        <button class="ghost-button"
                                                type="button"
                                                disabled="@isBusy"
                                                @onclick="() => HandleDeleteReview(review.Id)">
                                            Remover
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                    </article>
                </div>

                @if (salesDashboard.Compras.Count == 0)
                {
                    <div class="status-box">Ainda não existem compras para exibir na tabela comercial.</div>
                }
                else
                {
                    <div class="admin-sales-table-wrap">
                        <table class="admin-sales-table">
                            <thead>
                                <tr>
                                    <th>Cliente</th>
                                    <th>Evento</th>
                                    <th>Data da compra</th>
                                    <th>Forma de pagamento</th>
                                    <th>Status</th>
                                    <th>Valor</th>
                                    <th>Qtd</th>
                                    <th>Setor / cadeira / lote</th>
                                    <th>Pedido</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in salesDashboard.Compras)
                                {
                                    <tr>
                                        <td>
                                            <strong>@item.Cliente</strong>
                                            <span>@item.ClienteEmail</span>
                                        </td>
                                        <td>@item.Evento</td>
                                        <td>@item.DataCompra.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@GetPaymentMethodLabel(item.FormaPagamento)</td>
                                        <td>
                                            <span class="admin-status-pill @GetPaymentStatusClass(item.StatusPagamento)">
                                                @GetPaymentStatusLabel(item.StatusPagamento)
                                            </span>
                                        </td>
                                        <td>R$ @item.ValorPago.ToString("0.00")</td>
                                        <td>@item.QuantidadeIngressos</td>
                                        <td>@item.SetorCadeiraLote</td>
                                        <td>@item.CodigoPedido</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </section>
        }

        @if (activeAdminView == "operacao")
        {
        <div class="admin-grid">
            <section class="admin-panel">
                <div class="admin-panel__head">
                    <span class="admin-panel__pill">Cadastro</span>
                    <h2>Novo evento</h2>
                    <p>Cadastre um evento geek com nome, atração, data, preço e imagem de destaque.</p>
                </div>

                <EditForm Model="@eventModel" OnValidSubmit="HandleCreateEvent" FormName="admin-event-form" class="admin-form">
                    <DataAnnotationsValidator />
                    <div class="admin-form__grid">
                        <div class="field">
                            <label for="eventoNome">Nome do evento</label>
                            <InputText id="eventoNome" class="field__input" @bind-Value="eventModel.Nome" />
                            <ValidationMessage For="() => eventModel.Nome" />
                        </div>
                        <div class="field">
                            <label for="eventoArtista">Atração principal</label>
                            <InputText id="eventoArtista" class="field__input" @bind-Value="eventModel.Artista" />
                            <ValidationMessage For="() => eventModel.Artista" />
                        </div>
                    </div>
                    <div class="admin-form__grid">
                        <div class="field">
                            <label for="eventoLocal">Local do evento</label>
                            <InputText id="eventoLocal" class="field__input" @bind-Value="eventModel.LocalEvento" />
                            <ValidationMessage For="() => eventModel.LocalEvento" />
                        </div>
                        <div class="field">
                            <label for="eventoCidade">Cidade do evento</label>
                            <input id="eventoCidade" type="hidden" @bind="eventModel.CidadeEvento" />
                            <button class="field__input genre-picker-trigger" type="button" @onclick="OpenCreateCityModal">
                                <span>@(string.IsNullOrWhiteSpace(eventModel.CidadeEvento) ? "Selecionar cidade do evento" : eventModel.CidadeEvento)</span>
                                <strong>Selecionar</strong>
                            </button>
                            <ValidationMessage For="() => eventModel.CidadeEvento" />
                        </div>
                    </div>
                    <div class="admin-form__grid admin-form__grid--triple">
                        <div class="field">
                            <label for="eventoGenero">Categoria geek</label>
                            <input id="eventoGenero" type="hidden" @bind="eventModel.GeneroMusical" />
                            <button class="field__input genre-picker-trigger" type="button" @onclick="OpenCreateGenreModal">
                                <span>@(string.IsNullOrWhiteSpace(eventModel.GeneroMusical) ? "Selecionar categoria geek" : eventModel.GeneroMusical)</span>
                                <strong>Selecionar</strong>
                            </button>
                            <ValidationMessage For="() => eventModel.GeneroMusical" />
                        </div>
                        <div class="field">
                            <label for="eventoCapacidade">Capacidade</label>
                            <InputNumber id="eventoCapacidade" class="field__input" @bind-Value="eventModel.CapacidadeTotal" />
                            <ValidationMessage For="() => eventModel.CapacidadeTotal" />
                        </div>
                        <div class="field">
                            <label for="eventoPreco">Preco</label>
                            <InputNumber id="eventoPreco" class="field__input" @bind-Value="eventModel.PrecoPadrao" />
                            <ValidationMessage For="() => eventModel.PrecoPadrao" />
                        </div>
                    </div>
                    <div class="admin-form__grid">
                        <div class="field">
                            <label for="eventoData">Data e hora</label>
                            <InputDate id="eventoData" class="field__input" @bind-Value="eventDateOnly" />
                        </div>
                        <div class="field">
                            <label for="eventoHora">Horario</label>
                            <InputText id="eventoHora" class="field__input" @bind-Value="eventTime" />
                        </div>
                    </div>
                    <div class="field">
                        <label for="eventoImagem">Imagem (URL ou arquivo)</label>
                        <InputText id="eventoImagem" class="field__input" @bind-Value="eventModel.ImagemUrl" />
                        <ValidationMessage For="() => eventModel.ImagemUrl" />
                    </div>
                    <div class="field">
                        <label for="eventoImagemArquivo">Selecionar imagem do computador</label>
                        <InputFile id="eventoImagemArquivo" OnChange="HandleCreateImageSelected" accept="image/*" class="field__file-input" />
                        <span class="field__hint">Escolha uma imagem do PC do administrador para preencher automaticamente a capa do evento.</span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(eventModel.ImagemUrl))
                    {
                        <div class="admin-image-preview">
                            <img src="@eventModel.ImagemUrl" alt="Preview do evento" />
                            <div>
                                <strong>Preview da capa</strong>
                                <span>Confira como a imagem vai aparecer na vitrine do site.</span>
                            </div>
                        </div>
                    }

                    <button class="secondary-button" type="submit" disabled="@isBusy">Publicar evento</button>
                </EditForm>
            </section>

            <section class="admin-panel admin-panel--soft">
                <div class="admin-panel__head">
                    <span class="admin-panel__pill">Promoção</span>
                    <h2>Novo cupom</h2>
                    <p>Cadastre códigos promocionais para campanhas e ações especiais.</p>
                </div>

                <EditForm Model="@couponModel" OnValidSubmit="HandleCreateCoupon" FormName="admin-coupon-form" class="admin-form">
                    <DataAnnotationsValidator />
                    <div class="admin-form__grid">
                        <div class="field">
                            <label for="cupomCodigo">Código</label>
                            <InputText id="cupomCodigo" class="field__input" @bind-Value="couponModel.Codigo" />
                            <ValidationMessage For="() => couponModel.Codigo" />
                        </div>
                        <div class="field">
                            <label for="cupomDesconto">Desconto (%)</label>
                            <InputNumber id="cupomDesconto" class="field__input" @bind-Value="couponModel.PorcentagemDesconto" />
                            <ValidationMessage For="() => couponModel.PorcentagemDesconto" />
                        </div>
                    </div>
                    <div class="field">
                        <label for="cupomMinimo">Valor mínimo</label>
                        <InputNumber id="cupomMinimo" class="field__input" @bind-Value="couponModel.ValorMinimoRegra" />
                        <ValidationMessage For="() => couponModel.ValorMinimoRegra" />
                    </div>

                    <div class="admin-note">
                        <strong>Dica comercial</strong>
                        <span>Use códigos curtos e claros para campanhas como `GEEK10`, `COSPLAY20` ou `VIPGEEK`.</span>
                    </div>

                    <button class="primary-button" type="submit" disabled="@isBusy">Criar cupom</button>
                </EditForm>

                <div class="admin-subsection">
                    <div class="admin-subsection__head">
                        <div>
                            <h3>Cupons cadastrados</h3>
                            <p>Edite percentuais, revise regras minimas e remova cupons quando precisar.</p>
                        </div>
                        <button class="ghost-button" type="button" @onclick="LoadAdminCoupons" disabled="@isBusy">Atualizar</button>
                    </div>

                    @if (couponsLoading)
                    {
                        <div class="status-box">Carregando cupons cadastrados...</div>
                    }
                    else if (adminCoupons.Count == 0)
                    {
                        <div class="status-box">Nenhum cupom cadastrado ainda.</div>
                    }
                    else
                    {
                        <div class="admin-coupon-list">
                            @foreach (var item in adminCoupons)
                            {
                                var isEditingCoupon = editingCoupon is not null && editingCoupon.Codigo == item.Codigo;

                                <article class="admin-coupon-card">
                                    @if (isEditingCoupon)
                                    {
                                        <EditForm Model="@editingCoupon" OnValidSubmit="HandleUpdateCoupon" FormName="@($"edit-coupon-{item.Codigo}")" class="admin-form">
                                            <DataAnnotationsValidator />

                                            <div class="field">
                                                <label>Código</label>
                                                <InputText class="field__input" @bind-Value="editingCoupon!.Codigo" disabled />
                                            </div>
                                            <div class="admin-form__grid">
                                                <div class="field">
                                                    <label>Desconto (%)</label>
                                                    <InputNumber class="field__input" @bind-Value="editingCoupon!.PorcentagemDesconto" />
                                                    <ValidationMessage For="() => editingCoupon!.PorcentagemDesconto" />
                                                </div>
                                                <div class="field">
                                                    <label>Valor mínimo</label>
                                                    <InputNumber class="field__input" @bind-Value="editingCoupon!.ValorMinimoRegra" />
                                                    <ValidationMessage For="() => editingCoupon!.ValorMinimoRegra" />
                                                </div>
                                            </div>

                                            <div class="admin-event-card__actions">
                                                <button class="secondary-button" type="submit" disabled="@isBusy">Salvar</button>
                                                <button class="ghost-button" type="button" @onclick="CancelCouponEdit">Cancelar</button>
                                            </div>
                                        </EditForm>
                                    }
                                    else
                                    {
                                        <div class="admin-coupon-card__meta">
                                            <span class="pill">@item.Codigo</span>
                                            <span class="pill pill--muted">@item.PorcentagemDesconto.ToString("0")% off</span>
                                        </div>
                                        <strong>@item.Codigo</strong>
                                        <p>Desconto de <strong>@item.PorcentagemDesconto.ToString("0")%</strong> para compras a partir de <strong>R$ @item.ValorMinimoRegra.ToString("0.00")</strong>.</p>

                                        <div class="admin-event-card__actions">
                                            <button class="ghost-button" type="button" @onclick='() => StartCouponEdit(item)'>Editar</button>
                                            <button class="danger-button" type="button" @onclick='() => HandleDeleteCoupon(item.Codigo)'>Excluir</button>
                                        </div>
                                    }
                                </article>
                            }
                        </div>
                    }
                </div>
            </section>

            <section class="admin-panel">
                <div class="admin-panel__head">
                    <span class="admin-panel__pill">Convidados</span>
                    <h2>Convidados e associações</h2>
                    <p>Cadastre cosplayers, streamers, dubladores e associe presenças aos eventos.</p>
                </div>

                <EditForm Model="@guestModel" OnValidSubmit="HandleCreateGuest" FormName="admin-guest-form" class="admin-form">
                    <div class="admin-form__grid">
                        <div class="field">
                            <label for="guestNome">Nome</label>
                            <InputText id="guestNome" class="field__input" @bind-Value="guestModel.Nome" />
                        </div>
                        <div class="field">
                            <label for="guestTipo">Tipo</label>
                            <InputText id="guestTipo" class="field__input" @bind-Value="guestModel.Tipo" />
                        </div>
                    </div>
                    <div class="field">
                        <label for="guestBio">Bio</label>
                        <InputText id="guestBio" class="field__input" @bind-Value="guestModel.Bio" />
                    </div>
                    <div class="field">
                        <label for="guestFotoArquivo">Foto do convidado</label>
                        <InputFile id="guestFotoArquivo" OnChange="HandleGuestImageSelected" accept="image/*" class="field__file-input" />
                        <span class="field__hint">Escolha uma imagem do dispositivo para aparecer no card do convidado.</span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(guestModel.FotoUrl))
                    {
                        <div class="admin-image-preview">
                            <img src="@guestModel.FotoUrl" alt="Preview do convidado" />
                            <div>
                                <strong>Preview da foto</strong>
                                <span>Esta imagem será salva junto com o cadastro do convidado.</span>
                            </div>
                        </div>
                    }

                    <button class="primary-button" type="submit" disabled="@isBusy">Cadastrar convidado</button>
                </EditForm>

                <div class="admin-subsection">
                    <div class="admin-subsection__head">
                        <div>
                            <h3>Associar ao evento</h3>
                            <p>Escolha um evento e conecte os convidados confirmados.</p>
                        </div>
                        <button class="ghost-button" type="button" @onclick="LoadGuests" disabled="@isBusy">Atualizar</button>
                    </div>

                    <div class="admin-form">
                        <div class="admin-form__grid">
                            <div class="field">
                                <label for="guestEvent">Evento</label>
                                <select id="guestEvent" class="field__input" @bind="selectedGuestEventId" @bind:after="LoadSelectedEventGuests">
                                    <option value="0">Selecionar evento</option>
                                    @foreach (var item in adminEvents)
                                    {
                                        <option value="@item.Id">@item.Nome</option>
                                    }
                                </select>
                            </div>
                            <div class="field">
                                <label for="guestSelect">Convidado</label>
                                <select id="guestSelect" class="field__input" @bind="selectedGuestId">
                                    <option value="0">Selecionar convidado</option>
                                    @foreach (var item in adminGuests)
                                    {
                                        <option value="@item.Id">@item.Nome (@item.Tipo)</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <button class="secondary-button" type="button" @onclick="HandleLinkGuestToEvent" disabled="@isBusy">Associar convidado</button>
                    </div>

                    @if (selectedEventGuests.Count > 0)
                    {
                        <div class="admin-coupon-list">
                            @foreach (var guest in selectedEventGuests)
                            {
                                <article class="admin-coupon-card">
                                    <div class="admin-coupon-card__meta">
                                        <span class="pill">@guest.Tipo</span>
                                    </div>
                                    <strong>@guest.Nome</strong>
                                    <p>@guest.Bio</p>
                                    <div class="admin-event-card__actions">
                                        <button class="danger-button" type="button" @onclick="() => HandleUnlinkGuestFromEvent(guest.Id)">Remover do evento</button>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </div>
            </section>

            <section class="admin-panel admin-panel--soft">
                <div class="admin-panel__head">
                    <span class="admin-panel__pill">Check-in</span>
                    <h2>Validação de entrada</h2>
                    <p>Digite o código da reserva ou use a câmera do aparelho para ler o QR Code do participante.</p>
                </div>

                @if (checkinCodeLoadedFromUrl)
                {
                    <div class="admin-note">
                        <strong>Código recebido pelo QR Code.</strong>
                        <span>Confira os dados e clique em validar check-in para registrar a entrada.</span>
                    </div>
                }

                <div class="admin-form">
                    <div class="field">
                        <label for="checkinQr">QR Code</label>
                        <InputText id="checkinQr" class="field__input" @bind-Value="checkinQrCode" />
                    </div>
                    <div class="admin-checkin-actions">
                        <button class="secondary-button" type="button" @onclick="HandleValidateCheckin" disabled="@isBusy">Validar check-in</button>
                        @if (isQrScannerOpen)
                        {
                            <button class="ghost-button" type="button" @onclick="StopQrScanner" disabled="@isBusy">Fechar câmera</button>
                        }
                        else
                        {
                            <button class="ghost-button" type="button" @onclick="StartQrScanner" disabled="@isBusy">Abrir câmera</button>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(scannerMessage))
                {
                    <div class="admin-note @(scannerIsError ? "admin-note--error" : null)">
                        <strong>@scannerMessage</strong>
                        @if (scannerIsError)
                        {
                            <span>A validação manual continua disponível pelo campo acima.</span>
                        }
                    </div>
                }

                @if (isQrScannerOpen)
                {
                    <div class="admin-camera">
                        <video id="adminCheckinCamera" autoplay playsinline muted></video>
                        <span>Aponte a câmera para o QR Code ampliado no celular do cliente.</span>
                    </div>
                }

                @if (lastCheckinResult is not null)
                {
                    <div class="admin-note">
                        <strong>@lastCheckinResult.Mensagem</strong>
                        <span>@lastCheckinResult.EventoNome - reserva #@lastCheckinResult.ReservaId - @lastCheckinResult.Status</span>
                    </div>
                }
            </section>
        </div>

        <section class="admin-panel admin-panel--list">
            <div class="admin-list-header">
                <div>
                    <h2>Eventos cadastrados</h2>
                    <p>Edite os destaques da temporada, ajuste preços e remova eventos quando necessário.</p>
                </div>
                <button class="ghost-button" @onclick="LoadAdminEvents" disabled="@isBusy">Atualizar lista</button>
            </div>

            @if (eventsLoading)
            {
                <div class="status-box">Carregando eventos cadastrados...</div>
            }
            else if (adminEvents.Count == 0)
            {
                <div class="status-box">Nenhum evento cadastrado ainda.</div>
            }
            else
            {
                <div class="admin-event-list">
                    @foreach (var item in adminEvents)
                    {
                        <article class="admin-event-card">
                            @if (!string.IsNullOrWhiteSpace(item.ImagemUrl))
                            {
                                <img class="admin-event-card__image" src="@item.ImagemUrl" alt="@item.Nome" />
                            }

                            <div class="admin-event-card__body">
                                <div class="admin-event-card__meta">
                                    <span class="pill">@item.DataEvento.ToString("dd/MM/yyyy")</span>
                                    <span class="pill pill--muted">@item.CapacidadeTotal lugares</span>
                                </div>
                                <h3>@item.Nome</h3>
                                <p class="admin-event-card__copy">@item.LocalEvento, @item.CidadeEvento</p>
                                <p class="admin-event-card__copy">@item.Artista • @item.GeneroMusical</p>
                                <p class="admin-event-card__copy">@item.DataEvento.ToString("dd/MM/yyyy 'as' HH:mm")</p>
                                <div class="admin-event-card__pricing">
                                    <strong>R$ @item.PrecoPadrao.ToString("0.00")</strong>
                                    <span>@FormatRating(item)</span>
                                </div>

                                <div class="admin-event-card__actions">
                                    <button class="ghost-button" type="button" @onclick='() => StartEdit(item)'>Editar</button>
                                    <button class="danger-button" type="button" @onclick='() => HandleDeleteEvent(item.Id)'>Excluir</button>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
        }

        @if (editingEvent is not null)
        {
            <div class="admin-modal-backdrop" @onclick="CancelEdit">
                <div class="admin-modal" @onclick:stopPropagation="true">
                    <div class="admin-modal__header">
                        <div>
                            <span class="admin-panel__pill">Edição</span>
                            <h3>Editar evento</h3>
                             <p>Atualize os dados do evento sem perder a visão da agenda.</p>
                        </div>
                        <button class="admin-modal__close" type="button" @onclick="CancelEdit" aria-label="Fechar edição">×</button>
                    </div>

                    <EditForm Model="@editingEvent" OnValidSubmit="HandleUpdateEvent" FormName="@($"edit-event-{editingEvent.Id}")" class="admin-form">
                        <DataAnnotationsValidator />
                        <div class="admin-form__grid">
                            <div class="field">
                                <label>Nome</label>
                                <InputText class="field__input" @bind-Value="editingEvent.Nome" />
                                <ValidationMessage For="() => editingEvent.Nome" />
                            </div>
                            <div class="field">
                                <label>Atração principal</label>
                                <InputText class="field__input" @bind-Value="editingEvent.Artista" />
                                <ValidationMessage For="() => editingEvent.Artista" />
                            </div>
                        </div>
                        <div class="admin-form__grid">
                            <div class="field">
                                <label>Local</label>
                                <InputText class="field__input" @bind-Value="editingEvent.LocalEvento" />
                                <ValidationMessage For="() => editingEvent.LocalEvento" />
                            </div>
                            <div class="field">
                                <label>Cidade</label>
                                <input type="hidden" @bind="editingEvent.CidadeEvento" />
                                <button class="field__input genre-picker-trigger" type="button" @onclick="OpenEditCityModal">
                                    <span>@(string.IsNullOrWhiteSpace(editingEvent.CidadeEvento) ? "Selecionar cidade do evento" : editingEvent.CidadeEvento)</span>
                                    <strong>Selecionar</strong>
                                </button>
                                <ValidationMessage For="() => editingEvent.CidadeEvento" />
                            </div>
                        </div>
                        <div class="admin-form__grid admin-form__grid--triple">
                            <div class="field">
                                <label>Categoria geek</label>
                                <input type="hidden" @bind="editingEvent.GeneroMusical" />
                                <button class="field__input genre-picker-trigger" type="button" @onclick="OpenEditGenreModal">
                                    <span>@(string.IsNullOrWhiteSpace(editingEvent.GeneroMusical) ? "Selecionar categoria geek" : editingEvent.GeneroMusical)</span>
                                    <strong>Selecionar</strong>
                                </button>
                                <ValidationMessage For="() => editingEvent.GeneroMusical" />
                            </div>
                            <div class="field">
                                <label>Capacidade</label>
                                <InputNumber class="field__input" @bind-Value="editingEvent.CapacidadeTotal" />
                                <ValidationMessage For="() => editingEvent.CapacidadeTotal" />
                            </div>
                            <div class="field">
                                <label>Preco</label>
                                <InputNumber class="field__input" @bind-Value="editingEvent.PrecoPadrao" />
                                <ValidationMessage For="() => editingEvent.PrecoPadrao" />
                            </div>
                        </div>
                        <div class="admin-form__grid">
                            <div class="field">
                                <label>Data</label>
                                <InputDate class="field__input" @bind-Value="editDateOnly" />
                            </div>
                            <div class="field">
                                <label>Horario</label>
                                <InputText class="field__input" @bind-Value="editTime" />
                            </div>
                        </div>
                        <div class="field">
                            <label>Imagem (URL ou arquivo)</label>
                            <InputText class="field__input" @bind-Value="editingEvent.ImagemUrl" />
                            <ValidationMessage For="() => editingEvent.ImagemUrl" />
                        </div>
                        <div class="field">
                            <label>Selecionar imagem do computador</label>
                            <InputFile OnChange="HandleEditImageSelected" accept="image/*" class="field__file-input" />
                            <span class="field__hint">Você tambem pode escolher uma imagem local do computador para atualizar a capa do evento.</span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(editingEvent.ImagemUrl))
                        {
                            <div class="admin-image-preview">
                                <img src="@editingEvent.ImagemUrl" alt="Preview do evento em edição" />
                                <div>
                                    <strong>Preview da capa</strong>
                                    <span>Confira como a imagem atualizada vai aparecer na vitrine.</span>
                                </div>
                            </div>
                        }

                        <div class="admin-modal__actions">
                            <button class="secondary-button" type="submit" disabled="@isBusy">Salvar alteracoes</button>
                            <button class="ghost-button" type="button" @onclick="CancelEdit">Cancelar</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        }

        @if (isGenreModalOpen)
        {
            <div class="admin-modal-backdrop" @onclick="CloseGenreModal">
                <div class="admin-modal admin-modal--genre" @onclick:stopPropagation="true">
                    <div class="admin-modal__header">
                        <div>
                            <span class="admin-panel__pill">Categoria geek</span>
                            <h3>Selecionar ou adicionar categoria</h3>
                            <p>Escolha uma categoria salva ou cadastre uma nova para reutilizar sempre no painel.</p>
                        </div>
                        <button class="admin-modal__close" type="button" @onclick="CloseGenreModal" aria-label="Fechar categoria geek">×</button>
                    </div>

                    <div class="catalog-modal">
                        <div class="catalog-modal__list">
                            @foreach (var genre in availableGenres)
                            {
                                var isSelected = isSelectingGenreForCreate
                                    ? eventModel.GeneroMusical == genre
                                    : editingEvent?.GeneroMusical == genre;

                                <div class="catalog-option-row">
                                    <button class="genre-selector__option @(isSelected ? "genre-selector__option--selected" : null)"
                                            type="button"
                                            @onclick='() => SelectGenreFromModal(genre)'>
                                        <span class="genre-selector__check">@(isSelected ? "✓" : "")</span>
                                        <span>@genre</span>
                                    </button>

                                    <div class="catalog-option-row__actions">
                                        <button class="ghost-button" type="button" @onclick='() => StartGenreCatalogEdit(genre)'>Editar</button>
                                        <button class="danger-button" type="button" @onclick='() => HandleDeleteGenre(genre)'>Excluir</button>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="catalog-modal__composer">
                            <div class="field">
                                <label>@(editingGenreOriginalName is null ? "Nova categoria geek" : "Editar categoria geek")</label>
                                <InputText class="field__input" @bind-Value="genreModalInput" placeholder="Ex.: Anime, Games, Cosplay..." />
                            </div>

                            <div class="catalog-modal__actions">
                                <button class="ghost-button" type="button" @onclick="HandleGenreModalSubmit" disabled="@isBusy">
                                    @(editingGenreOriginalName is null ? "Adicionar categoria" : "Salvar alteracao")
                                </button>
                                @if (editingGenreOriginalName is not null)
                                {
                                    <button class="secondary-button" type="button" @onclick="CancelGenreCatalogEdit" disabled="@isBusy">Cancelar edição</button>
                                }
                                <button class="secondary-button" type="button" @onclick="CloseGenreModal">Concluir</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (isCityModalOpen)
        {
            <div class="admin-modal-backdrop" @onclick="CloseCityModal">
                <div class="admin-modal admin-modal--genre" @onclick:stopPropagation="true">
                    <div class="admin-modal__header">
                        <div>
                            <span class="admin-panel__pill">Cidade do evento</span>
                            <h3>Selecionar ou adicionar cidade</h3>
                            <p>Escolha uma cidade salva ou cadastre uma nova para reutilizar sempre no painel.</p>
                        </div>
                        <button class="admin-modal__close" type="button" @onclick="CloseCityModal" aria-label="Fechar cidade do evento">×</button>
                    </div>

                    <div class="catalog-modal">
                        <div class="catalog-modal__list">
                            @foreach (var city in availableCities)
                            {
                                var isSelected = isSelectingCityForCreate
                                    ? eventModel.CidadeEvento == city
                                    : editingEvent?.CidadeEvento == city;

                                <div class="catalog-option-row">
                                    <button class="genre-selector__option @(isSelected ? "genre-selector__option--selected" : null)"
                                            type="button"
                                            @onclick='() => SelectCityFromModal(city)'>
                                        <span class="genre-selector__check">@(isSelected ? "✓" : "")</span>
                                        <span>@city</span>
                                    </button>

                                    <div class="catalog-option-row__actions">
                                        <button class="ghost-button" type="button" @onclick='() => StartCityCatalogEdit(city)'>Editar</button>
                                        <button class="danger-button" type="button" @onclick='() => HandleDeleteCity(city)'>Excluir</button>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="catalog-modal__composer">
                            <div class="field">
                                <label>@(editingCityOriginalName is null ? "Nova cidade" : "Editar cidade")</label>
                                <InputText class="field__input" @bind-Value="cityModalInput" placeholder="Ex.: Recife, Campinas, Fortaleza..." />
                            </div>

                            <div class="catalog-modal__actions">
                                <button class="ghost-button" type="button" @onclick="HandleCityModalSubmit" disabled="@isBusy">
                                    @(editingCityOriginalName is null ? "Adicionar cidade" : "Salvar alteracao")
                                </button>
                                @if (editingCityOriginalName is not null)
                                {
                                    <button class="secondary-button" type="button" @onclick="CancelCityCatalogEdit" disabled="@isBusy">Cancelar edição</button>
                                }
                                <button class="secondary-button" type="button" @onclick="CloseCityModal">Concluir</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <div class="status-box @(isError ? "status-box--error" : "status-box--success")">
                @statusMessage
            </div>
        }
    </div>
}

@code {
    private readonly AdminEventInputModel eventModel = new();
    private readonly AdminCouponInputModel couponModel = new();
    private readonly GuestViewModel guestModel = new();
    private readonly List<EventViewModel> adminEvents = new();
    private readonly List<CouponViewModel> adminCoupons = new();
    private readonly List<GuestViewModel> adminGuests = new();
    private readonly List<GuestViewModel> selectedEventGuests = new();
    private readonly List<string> availableGenres = new();
    private readonly List<string> availableCities = new();
    private AdminSalesDashboardViewModel? salesDashboard;
    private string activeAdminView = "operacao";
    private bool isBusy;
    private bool isError;
    private bool eventsLoading;
    private bool couponsLoading;
    private bool salesLoading;
    private string statusMessage = string.Empty;
    private DateTime eventDateOnly = DateTime.Today.AddDays(15);
    private string eventTime = "20:00";
    private AdminEventEditModel? editingEvent;
    private AdminCouponEditModel? editingCoupon;
    private DateTime editDateOnly = DateTime.Today;
    private string editTime = "20:00";
    private bool isGenreModalOpen;
    private bool isSelectingGenreForCreate = true;
    private string genreModalInput = string.Empty;
    private string? editingGenreOriginalName;
    private bool isCityModalOpen;
    private bool isSelectingCityForCreate = true;
    private string cityModalInput = string.Empty;
    private string? editingCityOriginalName;
    private int selectedGuestEventId;
    private int selectedGuestId;
    private string checkinQrCode = string.Empty;
    private bool checkinCodeLoadedFromUrl;
    private bool isQrScannerOpen;
    private bool scannerIsError;
    private string scannerMessage = string.Empty;
    private DotNetObjectReference<Admin>? qrScannerReference;
    private CheckinResponseViewModel? lastCheckinResult;

    protected override async Task OnInitializedAsync()
    {
        LoadCheckinCodeFromUrl();
        eventDateOnly = eventModel.DataEvento.Date;
        eventTime = eventModel.DataEvento.ToString("HH:mm");
        await LoadGenresAsync();
        await LoadCitiesAsync();
        await LoadAdminEvents();
        await LoadAdminCoupons();
        await LoadGuests();
        await LoadAdminSalesDashboard();
    }

    private void LoadCheckinCodeFromUrl()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("checkin", out var value) && !string.IsNullOrWhiteSpace(value))
        {
            checkinQrCode = value.ToString();
            checkinCodeLoadedFromUrl = true;
        }
    }

    private void OpenAdminLogin()
    {
        AuthOverlay.OpenLogin();
    }

    private async Task StartQrScanner()
    {
        scannerMessage = string.Empty;
        scannerIsError = false;
        isQrScannerOpen = true;
        qrScannerReference ??= DotNetObjectReference.Create(this);
        await InvokeAsync(StateHasChanged);
        await Task.Delay(50);

        try
        {
            await JS.InvokeVoidAsync("geekTopQrScanner.start", "adminCheckinCamera", qrScannerReference);
            scannerMessage = "Câmera aberta. Aponte para o QR Code do cliente.";
        }
        catch (Exception ex)
        {
            isQrScannerOpen = false;
            scannerIsError = true;
            scannerMessage = ex.Message;
        }
    }

    private async Task StopQrScanner()
    {
        try
        {
            await JS.InvokeVoidAsync("geekTopQrScanner.stop");
        }
        catch
        {
            // A câmera pode já ter sido liberada pelo navegador.
        }
        finally
        {
            isQrScannerOpen = false;
        }
    }

    [JSInvokable]
    public async Task OnQrCodeScanned(string rawValue)
    {
        checkinQrCode = ExtractQrCode(rawValue);
        isQrScannerOpen = false;
        scannerIsError = false;
        scannerMessage = "QR Code lido. Confira o código e valide o check-in.";
        await InvokeAsync(StateHasChanged);
    }

    private static string ExtractQrCode(string rawValue)
    {
        var value = rawValue.Trim();

        if (Uri.TryCreate(value, UriKind.Absolute, out var uri))
        {
            var query = QueryHelpers.ParseQuery(uri.Query);
            if (query.TryGetValue("checkin", out var checkinCode) && !string.IsNullOrWhiteSpace(checkinCode))
                return checkinCode.ToString();
        }

        return value;
    }

    private async Task HandleCreateEvent()
    {
        statusMessage = string.Empty;
        isError = false;
        isBusy = true;

        try
        {
            var schedule = BuildEventDateTime();
            var result = await ApiClient.CreateEventAsync(new EventCreateRequest
            {
                Nome = eventModel.Nome,
                LocalEvento = eventModel.LocalEvento,
                CidadeEvento = eventModel.CidadeEvento,
                Artista = eventModel.Artista,
                GeneroMusical = eventModel.GeneroMusical,
                CapacidadeTotal = eventModel.CapacidadeTotal,
                DataEvento = schedule,
                PrecoPadrao = eventModel.PrecoPadrao,
                ImagemUrl = eventModel.ImagemUrl
            }, Session.AdminToken!);

            isError = !result.Success;
            statusMessage = result.Message;

            if (result.Success)
            {
                eventModel.Nome = string.Empty;
                eventModel.LocalEvento = string.Empty;
                eventModel.CidadeEvento = string.Empty;
                eventModel.Artista = string.Empty;
                eventModel.GeneroMusical = string.Empty;
                eventModel.CapacidadeTotal = 1000;
                eventModel.PrecoPadrao = 99.90m;
                eventModel.ImagemUrl = string.Empty;
                eventDateOnly = DateTime.Today.AddDays(15);
                eventTime = "20:00";
                if (availableGenres.Count > 0)
                    eventModel.GeneroMusical = availableGenres[0];
                if (availableCities.Count > 0)
                    eventModel.CidadeEvento = availableCities[0];
                await LoadAdminEvents();
                await LoadAdminSalesDashboard();
            }
        }
        catch
        {
            isError = true;
            statusMessage = "Não foi possível publicar o evento agora.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task HandleCreateCoupon()
    {
        statusMessage = string.Empty;
        isError = false;
        isBusy = true;

        try
        {
            var result = await ApiClient.CreateCouponAsync(new CouponCreateRequest
            {
                Codigo = couponModel.Codigo,
                PorcentagemDesconto = couponModel.PorcentagemDesconto,
                ValorMinimoRegra = couponModel.ValorMinimoRegra
            }, Session.AdminToken!);

            isError = !result.Success;
            statusMessage = result.Message;

            if (result.Success)
            {
                couponModel.Codigo = string.Empty;
                couponModel.PorcentagemDesconto = 10;
                couponModel.ValorMinimoRegra = 50;
                await LoadAdminCoupons();
            }
        }
        catch
        {
            isError = true;
            statusMessage = "Não foi possível criar o cupom agora.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private DateTime BuildEventDateTime()
    {
        if (TimeOnly.TryParse(eventTime, out var parsedTime))
            return eventDateOnly.Date.Add(parsedTime.ToTimeSpan());

        return eventDateOnly.Date.AddHours(20);
    }

    private async Task HandleCreateImageSelected(InputFileChangeEventArgs args)
    {
        if (args.FileCount == 0)
            return;

        try
        {
            eventModel.ImagemUrl = await ConvertFileToDataUrlAsync(args.File);
            statusMessage = "Imagem carregada do computador com sucesso.";
            isError = false;
        }
        catch
        {
            statusMessage = "Não foi possível carregar a imagem selecionada.";
            isError = true;
        }
    }

    private async Task HandleGuestImageSelected(InputFileChangeEventArgs args)
    {
        if (args.FileCount == 0)
            return;

        try
        {
            guestModel.FotoUrl = await ConvertFileToDataUrlAsync(args.File);
            statusMessage = "Foto do convidado carregada com sucesso.";
            isError = false;
        }
        catch
        {
            statusMessage = "Não foi possível carregar a foto selecionada.";
            isError = true;
        }
    }

    private async Task LoadAdminEvents()
    {
        if (string.IsNullOrWhiteSpace(Session.AdminToken))
            return;

        eventsLoading = true;

        try
        {
            adminEvents.Clear();
            adminEvents.AddRange(await ApiClient.GetAdminEventsAsync(Session.AdminToken));

            if (selectedGuestEventId == 0 && adminEvents.Count > 0)
                selectedGuestEventId = adminEvents[0].Id;
        }
        finally
        {
            eventsLoading = false;
        }
    }

    private async Task LoadAdminSalesDashboard()
    {
        if (string.IsNullOrWhiteSpace(Session.AdminToken))
            return;

        salesLoading = true;

        try
        {
            salesDashboard = await ApiClient.GetAdminSalesDashboardAsync(Session.AdminToken);
        }
        finally
        {
            salesLoading = false;
        }
    }

    private void SetAdminView(string view)
    {
        activeAdminView = view;
    }

    private async Task HandleDeleteReview(int reviewId)
    {
        if (string.IsNullOrWhiteSpace(Session.AdminToken))
            return;

        statusMessage = string.Empty;
        isBusy = true;

        try
        {
            var result = await ApiClient.DeleteReviewAsync(reviewId, Session.AdminToken);
            isError = !result.Success;
            statusMessage = result.Message;

            if (result.Success)
                await LoadAdminSalesDashboard();
        }
        catch
        {
            isError = true;
            statusMessage = "Não foi possível remover a avaliação agora.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task LoadGenresAsync()
    {
        if (string.IsNullOrWhiteSpace(Session.AdminToken))
            return;

        availableGenres.Clear();
        availableGenres.AddRange(await ApiClient.GetAdminGenresAsync(Session.AdminToken));

        if (string.IsNullOrWhiteSpace(eventModel.GeneroMusical) && availableGenres.Count > 0)
            eventModel.GeneroMusical = availableGenres[0];

        if (editingEvent is not null &&
            !string.IsNullOrWhiteSpace(editingEvent.GeneroMusical) &&
            !availableGenres.Contains(editingEvent.GeneroMusical))
        {
            availableGenres.Add(editingEvent.GeneroMusical);
        }

        if (!string.IsNullOrWhiteSpace(eventModel.GeneroMusical) &&
            !availableGenres.Contains(eventModel.GeneroMusical) &&
            availableGenres.Count > 0)
        {
            eventModel.GeneroMusical = availableGenres[0];
        }
    }

    private async Task LoadCitiesAsync()
    {
        if (string.IsNullOrWhiteSpace(Session.AdminToken))
            return;

        availableCities.Clear();
        availableCities.AddRange(await ApiClient.GetAdminCitiesAsync(Session.AdminToken));

        if (string.IsNullOrWhiteSpace(eventModel.CidadeEvento) && availableCities.Count > 0)
            eventModel.CidadeEvento = availableCities[0];

        if (editingEvent is not null &&
            !string.IsNullOrWhiteSpace(editingEvent.CidadeEvento) &&
            !availableCities.Contains(editingEvent.CidadeEvento))
        {
            availableCities.Add(editingEvent.CidadeEvento);
        }

        if (!string.IsNullOrWhiteSpace(eventModel.CidadeEvento) &&
            !availableCities.Contains(eventModel.CidadeEvento) &&
            availableCities.Count > 0)
        {
            eventModel.CidadeEvento = availableCities[0];
        }
    }

    private async Task LoadAdminCoupons()
    {
        if (string.IsNullOrWhiteSpace(Session.AdminToken))
            return;

