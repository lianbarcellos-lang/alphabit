                                @if (editingCityOriginalName is not null)
                                {
                                    <button class="secondary-button" type="button" @onclick="CancelCityCatalogEdit" disabled="@isBusy">Cancelar edição</button>
                                }
                                <button class="secondary-button" type="button" @onclick="CloseCityModal">Concluir</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <div class="status-box @(isError ? "status-box--error" : "status-box--success")">
                @statusMessage
            </div>
        }
    </div>
}

@code {
    private readonly AdminEventInputModel eventModel = new();
    private readonly AdminCouponInputModel couponModel = new();
    private readonly GuestViewModel guestModel = new();
    private readonly List<EventViewModel> adminEvents = new();
    private readonly List<CouponViewModel> adminCoupons = new();
    private readonly List<GuestViewModel> adminGuests = new();
    private readonly List<GuestViewModel> selectedEventGuests = new();
    private readonly List<StandSpaceViewModel> eventStands = new();
    private readonly List<string> standSectors = new();
    private readonly List<string> availableGenres = new();
    private readonly List<string> availableCities = new();
    private readonly StandAllocationRequest standAllocationModel = new();
    private readonly Dictionary<string, string> sectorRenameInputs = new(StringComparer.OrdinalIgnoreCase);
    private readonly IReadOnlyList<StandLayoutOption> standLayoutOptions =
    [
        new("2x2", 2),
        new("3x3", 3),
        new("4x4", 4),
        new("5x5", 5),
        new("8x8", 8)
    ];
    private const string StandMapDropElementId = "admin-stand-image-map";
    private AdminSalesDashboardViewModel? salesDashboard;
    private string activeAdminView = "operacao";
    private bool isBusy;
    private bool isError;
    private bool eventsLoading;
    private bool couponsLoading;
    private bool salesLoading;
    private string statusMessage = string.Empty;
    private DateTime eventDateOnly = DateTime.Today.AddDays(15);
    private string eventTime = "20:00";
    private AdminEventEditModel? editingEvent;
    private AdminCouponEditModel? editingCoupon;
    private DateTime editDateOnly = DateTime.Today;
    private string editTime = "20:00";
    private bool isGenreModalOpen;
    private bool isSelectingGenreForCreate = true;
    private string genreModalInput = string.Empty;
    private string? editingGenreOriginalName;
    private bool isCityModalOpen;
    private bool isSelectingCityForCreate = true;
    private string cityModalInput = string.Empty;
    private string? editingCityOriginalName;
    private int selectedGuestEventId;
    private int selectedGuestId;
    private int selectedStandEventId;
    private int selectedStandId;
    private int draggedStandId;
    private string standMapImageUrl = string.Empty;
    private string standEditCode = string.Empty;
    private string standEditSector = string.Empty;
    private string newStandSectorName = string.Empty;
    private string checkinQrCode = string.Empty;
    private bool checkinCodeLoadedFromUrl;
    private bool isQrScannerOpen;
    private bool scannerIsError;
    private string scannerMessage = string.Empty;
    private DotNetObjectReference<Admin>? qrScannerReference;
    private DotNetObjectReference<Admin>? standMapReference;
    private CheckinResponseViewModel? lastCheckinResult;

    protected override async Task OnInitializedAsync()
    {
        LoadCheckinCodeFromUrl();
        eventDateOnly = eventModel.DataEvento.Date;
        eventTime = eventModel.DataEvento.ToString("HH:mm");
        await LoadGenresAsync();
        await LoadCitiesAsync();
        await LoadAdminEvents();
        await LoadAdminCoupons();
        await LoadGuests();
        await LoadEventStands();
        await LoadAdminSalesDashboard();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!Session.IsAdmin || string.IsNullOrWhiteSpace(Session.AdminToken))
            return;

        standMapReference ??= DotNetObjectReference.Create(this);

        try
        {
            await JS.InvokeVoidAsync("geekTopStandMap.enablePinDragging", StandMapDropElementId, standMapReference);
        }
        catch
        {
            // O mapa pode não estar renderizado quando outra aba do painel está ativa.
        }
    }

    private void LoadCheckinCodeFromUrl()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("checkin", out var value) && !string.IsNullOrWhiteSpace(value))
        {
            checkinQrCode = value.ToString();
            checkinCodeLoadedFromUrl = true;
        }
    }

    private void OpenAdminLogin()
    {
        AuthOverlay.OpenLogin();
    }

    private async Task StartQrScanner()
    {
        scannerMessage = string.Empty;
        scannerIsError = false;
        isQrScannerOpen = true;
        qrScannerReference ??= DotNetObjectReference.Create(this);
        await InvokeAsync(StateHasChanged);
        await Task.Delay(50);

        try
        {
            await JS.InvokeVoidAsync("geekTopQrScanner.start", "adminCheckinCamera", qrScannerReference);
            scannerMessage = "Câmera aberta. Aponte para o QR Code do cliente.";
        }
        catch (Exception ex)
        {
            isQrScannerOpen = false;
            scannerIsError = true;
            scannerMessage = ex.Message;
        }
    }

    private async Task StopQrScanner()
    {
        try
        {
            await JS.InvokeVoidAsync("geekTopQrScanner.stop");
        }
        catch
        {
            // A câmera pode já ter sido liberada pelo navegador.
        }
        finally
        {
            isQrScannerOpen = false;
        }
    }

    [JSInvokable]
    public async Task OnQrCodeScanned(string rawValue)
    {
        checkinQrCode = ExtractQrCode(rawValue);
        isQrScannerOpen = false;
        scannerIsError = false;
        scannerMessage = "QR Code lido. Confira o código e valide o check-in.";
        await InvokeAsync(StateHasChanged);
    }

    private static string ExtractQrCode(string rawValue)
    {
        var value = rawValue.Trim();

        if (Uri.TryCreate(value, UriKind.Absolute, out var uri))
        {
            var query = QueryHelpers.ParseQuery(uri.Query);
            if (query.TryGetValue("checkin", out var checkinCode) && !string.IsNullOrWhiteSpace(checkinCode))
                return checkinCode.ToString();
        }

        return value;
    }

    private async Task HandleCreateEvent()
    {
        statusMessage = string.Empty;
        isError = false;
        isBusy = true;

        try
        {
            var schedule = BuildEventDateTime();
            var result = await ApiClient.CreateEventAsync(new EventCreateRequest
            {
                Nome = eventModel.Nome,
                LocalEvento = eventModel.LocalEvento,
                CidadeEvento = eventModel.CidadeEvento,
                Artista = eventModel.Artista,
                GeneroMusical = eventModel.GeneroMusical,
                CapacidadeTotal = eventModel.CapacidadeTotal,
                DataEvento = schedule,
                PrecoPadrao = eventModel.PrecoPadrao,
                ImagemUrl = eventModel.ImagemUrl
            }, Session.AdminToken!);

            isError = !result.Success;
            statusMessage = result.Message;

            if (result.Success)
            {
                eventModel.Nome = string.Empty;
                eventModel.LocalEvento = string.Empty;
                eventModel.CidadeEvento = string.Empty;
                eventModel.Artista = string.Empty;
                eventModel.GeneroMusical = string.Empty;
                eventModel.CapacidadeTotal = 1000;
                eventModel.PrecoPadrao = 99.90m;
                eventModel.ImagemUrl = string.Empty;
                eventDateOnly = DateTime.Today.AddDays(15);
                eventTime = "20:00";
                if (availableGenres.Count > 0)
                    eventModel.GeneroMusical = availableGenres[0];
                if (availableCities.Count > 0)
                    eventModel.CidadeEvento = availableCities[0];
                await LoadAdminEvents();
                await LoadAdminSalesDashboard();
            }
        }
        catch
        {
            isError = true;
            statusMessage = "Não foi possível publicar o evento agora.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task HandleCreateCoupon()
    {
        statusMessage = string.Empty;
        isError = false;
        isBusy = true;

        try
        {
            var result = await ApiClient.CreateCouponAsync(new CouponCreateRequest
            {
                Codigo = couponModel.Codigo,
                PorcentagemDesconto = couponModel.PorcentagemDesconto,
                ValorMinimoRegra = couponModel.ValorMinimoRegra
            }, Session.AdminToken!);

            isError = !result.Success;
            statusMessage = result.Message;

            if (result.Success)
            {
                couponModel.Codigo = string.Empty;
                couponModel.PorcentagemDesconto = 10;
                couponModel.ValorMinimoRegra = 50;
                await LoadAdminCoupons();
            }
        }
        catch
        {
            isError = true;
            statusMessage = "Não foi possível criar o cupom agora.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private DateTime BuildEventDateTime()
    {
        if (TimeOnly.TryParse(eventTime, out var parsedTime))
            return eventDateOnly.Date.Add(parsedTime.ToTimeSpan());

        return eventDateOnly.Date.AddHours(20);
    }

    private async Task HandleCreateImageSelected(InputFileChangeEventArgs args)
    {
        if (args.FileCount == 0)
            return;

        try
        {
            eventModel.ImagemUrl = await ConvertFileToDataUrlAsync(args.File);
            statusMessage = "Imagem carregada do computador com sucesso.";
            isError = false;
        }
        catch
        {
            statusMessage = "Não foi possível carregar a imagem selecionada.";
            isError = true;
        }
    }

    private async Task HandleGuestImageSelected(InputFileChangeEventArgs args)
    {
        if (args.FileCount == 0)
            return;

        try
        {
            guestModel.FotoUrl = await ConvertFileToDataUrlAsync(args.File);
            statusMessage = "Foto do convidado carregada com sucesso.";
            isError = false;
        }
        catch
        {
            statusMessage = "Não foi possível carregar a foto selecionada.";
            isError = true;
        }
    }

    private async Task LoadAdminEvents()
    {
        if (string.IsNullOrWhiteSpace(Session.AdminToken))
            return;

        eventsLoading = true;

        try
        {
            adminEvents.Clear();
            adminEvents.AddRange(await ApiClient.GetAdminEventsAsync(Session.AdminToken));

            if (selectedGuestEventId == 0 && adminEvents.Count > 0)
                selectedGuestEventId = adminEvents[0].Id;

            if (selectedStandEventId == 0 && adminEvents.Count > 0)
                selectedStandEventId = adminEvents[0].Id;
        }
        finally
        {
            eventsLoading = false;
        }
    }

    private StandSpaceViewModel? selectedStand => eventStands.FirstOrDefault(stand => stand.Id == selectedStandId);

    private bool HasStandMapImage => !string.IsNullOrWhiteSpace(standMapImageUrl);

    private void PrepareNewStandForm()
    {
        selectedStandId = 0;
        draggedStandId = 0;
        standEditCode = string.Empty;
        ResetStandAllocationModel();

        var sectorNames = GetStandSectorNames();
        standEditSector = sectorNames.Count > 0 ? sectorNames[0] : string.Empty;
    }

    private async Task LoadEventStands()
    {
        eventStands.Clear();
        PrepareNewStandForm();
        standMapImageUrl = string.Empty;

        if (selectedStandEventId <= 0)
            return;

        standSectors.Clear();
        standSectors.AddRange(await ApiClient.GetEventStandSectorsAsync(selectedStandEventId));
        eventStands.AddRange(await ApiClient.GetEventStandsAsync(selectedStandEventId));
        standMapImageUrl = eventStands.FirstOrDefault(stand => !string.IsNullOrWhiteSpace(stand.MapaImagemUrl))?.MapaImagemUrl ?? string.Empty;
        RefreshSectorRenameInputs();

        var sectorNames = GetStandSectorNames();
        if (string.IsNullOrWhiteSpace(standEditSector) || !sectorNames.Contains(standEditSector, StringComparer.OrdinalIgnoreCase))
            standEditSector = sectorNames[0];
    }

    private async Task HandleStandEventChanged(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var eventId))
        {
            selectedStandEventId = eventId;
            await LoadEventStands();
        }
    }

    private void SelectStand(StandSpaceViewModel stand)
    {
        selectedStandId = stand.Id;
        standAllocationModel.Reservado = stand.Reservado;
        standAllocationModel.TipoArea = string.IsNullOrWhiteSpace(stand.TipoArea) ? "Stand" : stand.TipoArea;
        standAllocationModel.AreaX = stand.AreaX;
        standAllocationModel.AreaY = stand.AreaY;
        standAllocationModel.AreaLargura = stand.AreaLargura <= 0 ? 12 : stand.AreaLargura;
        standAllocationModel.AreaAltura = stand.AreaAltura <= 0 ? 8 : stand.AreaAltura;
        standAllocationModel.AreaMetrosQuadrados = stand.AreaMetrosQuadrados;
        standAllocationModel.PrecoPorMetroQuadrado = stand.PrecoPorMetroQuadrado;
        standAllocationModel.PrecoFixo = stand.PrecoFixo;
        standAllocationModel.NomeOcupante = stand.NomeOcupante;
        standAllocationModel.TipoOcupante = stand.TipoOcupante;
        standAllocationModel.Descricao = stand.Descricao;
        standEditCode = stand.Codigo;
        standEditSector = NormalizeStandSector(stand.Setor);
    }

    private async Task HandleStandMapImageSelected(InputFileChangeEventArgs args)
    {
        if (selectedStandEventId <= 0 || string.IsNullOrWhiteSpace(Session.AdminToken) || args.FileCount == 0)
            return;

        try
        {
            var dataUrl = await ConvertFileToDataUrlAsync(args.File);
            await SaveStandMapImage(dataUrl);
        }
        catch
        {
            statusMessage = "Não foi possível carregar a planta selecionada.";
            isError = true;
        }
    }

    private async Task SaveStandMapImageFromInput()
    {
        await SaveStandMapImage(standMapImageUrl);
    }

    private async Task SaveStandMapImage(string mapImageUrl)
    {
        if (selectedStandEventId <= 0 || string.IsNullOrWhiteSpace(Session.AdminToken))
            return;

        isBusy = true;
        isError = false;
        statusMessage = string.Empty;

        try
        {
            var result = await ApiClient.UpdateEventMapImageAsync(selectedStandEventId, mapImageUrl.Trim(), Session.AdminToken);
            isError = !result.Success;
            statusMessage = result.Message;

            if (result.Success)
            {
                standMapImageUrl = mapImageUrl.Trim();
                await LoadEventStands();
            }
        }
        catch
        {
            isError = true;
            statusMessage = "Não foi possível salvar a planta do evento agora.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task CreateStand()
    {
        if (selectedStandEventId <= 0 || string.IsNullOrWhiteSpace(Session.AdminToken))
            return;

        var code = standEditCode.Trim();
        if (string.IsNullOrWhiteSpace(code))
        {
            isError = true;
            statusMessage = "Informe o código do stand.";
            return;
        }

        if (eventStands.Any(stand => string.Equals(stand.Codigo, code, StringComparison.OrdinalIgnoreCase)))
        {
            isError = true;
            statusMessage = "Já existe outro stand com este código.";
            return;
        }

        var occupantName = standAllocationModel.NomeOcupante.Trim();
        if (HasDuplicateStandName(occupantName))
        {
            isError = true;
            statusMessage = "Já existe um stand cadastrado com esse nome.";
            return;
        }

        isBusy = true;
        isError = false;
        statusMessage = string.Empty;

        try
        {
            var createRequest = new StandAllocationRequest
            {
                Codigo = code,
                Setor = NormalizeStandSector(standEditSector),
                TipoArea = "Stand",
                Reservado = !string.IsNullOrWhiteSpace(occupantName),
                AreaX = GetNextStandMapX(),
                AreaY = GetNextStandMapY(),
                AreaLargura = standAllocationModel.AreaLargura <= 0 ? 12 : standAllocationModel.AreaLargura,
                AreaAltura = standAllocationModel.AreaAltura <= 0 ? 8 : standAllocationModel.AreaAltura,
                AreaMetrosQuadrados = Math.Max(0, standAllocationModel.AreaMetrosQuadrados),
                PrecoPorMetroQuadrado = Math.Max(0, standAllocationModel.PrecoPorMetroQuadrado),
                PrecoFixo = Math.Max(0, standAllocationModel.PrecoFixo),
                NomeOcupante = occupantName,
                TipoOcupante = standAllocationModel.TipoOcupante.Trim(),
                Descricao = standAllocationModel.Descricao.Trim()
            };

            var result = await ApiClient.CreateStandAsync(selectedStandEventId, createRequest, Session.AdminToken);
            isError = !result.Success;
            statusMessage = result.Message;

            if (result.Success)
            {
                await LoadEventStands();
                statusMessage = "Stand cadastrado com sucesso. O formulário já está pronto para cadastrar outro stand.";
            }
        }
        catch
        {
            isError = true;
            statusMessage = "Não foi possível cadastrar o stand agora.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private IReadOnlyList<string> GetStandSectorNames()
    {
        var names = eventStands
            .Select(stand => NormalizeStandSector(stand.Setor))
            .Concat(standSectors.Select(NormalizeStandSector))
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(name => name)
            .ToList();

        if (names.Count == 0)
            names.Add("Linha 1");

        return names;
    }

    private IEnumerable<StandSectorGroup> GetStandSectorGroups()
    {
        return GetStandSectorNames()
            .Select(name => new StandSectorGroup(
                name,
                eventStands
                    .Where(stand => string.Equals(NormalizeStandSector(stand.Setor), name, StringComparison.OrdinalIgnoreCase))
                    .OrderBy(stand => stand.Codigo)
                    .ToList()))
            .OrderBy(group => group.Key);
    }

    private static IReadOnlyList<StandSpaceViewModel> GetVisibleSectorStands(IReadOnlyList<StandSpaceViewModel> stands)
    {
        return stands
            .OrderBy(stand => stand.Codigo)
            .ToList();
    }

    private string BuildSectorStandLabel(StandSpaceViewModel stand)
    {
        return stand.Reservado && !string.IsNullOrWhiteSpace(stand.NomeOcupante)
            ? stand.NomeOcupante
            : "Disponível";
    }

    private bool HasDuplicateStandName(string? occupantName, int? ignoredStandId = null)
    {
        var normalizedName = (occupantName ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(normalizedName))
            return false;

        return eventStands.Any(stand =>
            (!ignoredStandId.HasValue || stand.Id != ignoredStandId.Value) &&
            string.Equals(stand.NomeOcupante?.Trim(), normalizedName, StringComparison.OrdinalIgnoreCase));
    }

    private double GetNextStandMapX()
    {
        return GetNextStandMapPoint().X;
    }

    private double GetNextStandMapY()
    {
        return GetNextStandMapPoint().Y;
    }

    private StandMapPoint GetNextStandMapPoint()
    {
        var index = eventStands.Count;
        var column = index % 6;
        var row = index / 6;

        var x = 12 + column * 14;
        var y = 18 + (row % 5) * 14;

        return new StandMapPoint
        {
            X = Math.Clamp(x, 6, 94),
            Y = Math.Clamp(y, 8, 92)
        };
    }

    private string NormalizeStandSector(string? sector)
    {
        var value = (sector ?? string.Empty).Trim();
        if (value.Length == 0 || value.Equals("Ajustes manuais", StringComparison.OrdinalIgnoreCase))
            return GetDefaultStandSector();

        return value;
    }

    private string GetDefaultStandSector()
    {
        return standSectors
            .Select(sector => sector.Trim())
            .FirstOrDefault(sector => sector.Length > 0 && !sector.Equals("Ajustes manuais", StringComparison.OrdinalIgnoreCase))
            ?? eventStands
            .Select(stand => stand.Setor?.Trim() ?? string.Empty)
            .FirstOrDefault(sector => sector.Length > 0 && !sector.Equals("Ajustes manuais", StringComparison.OrdinalIgnoreCase))
            ?? "Linha 1";
    }

    private void RefreshSectorRenameInputs()
    {
        foreach (var sectorName in GetStandSectorNames())
        {
            if (!sectorRenameInputs.ContainsKey(sectorName))
                sectorRenameInputs[sectorName] = sectorName;
        }
    }

    private string GetSectorDraftName(string sectorName)
    {
        return sectorRenameInputs.TryGetValue(sectorName, out var draft)
            ? draft
            : sectorName;
    }

    private void SetSectorDraftName(string sectorName, string? value)
    {
        sectorRenameInputs[sectorName] = value ?? string.Empty;
    }

    private async Task CreateStandSector()
    {
        if (selectedStandEventId <= 0 || string.IsNullOrWhiteSpace(Session.AdminToken))
            return;

        var name = newStandSectorName.Trim();
        if (string.IsNullOrWhiteSpace(name))
        {
            isError = true;
            statusMessage = "Informe o nome da nova linha.";
            return;
        }

        isBusy = true;
        isError = false;
        statusMessage = string.Empty;

        try
        {
            var result = await ApiClient.CreateStandSectorAsync(selectedStandEventId, name, Session.AdminToken);
            isError = !result.Success;
            statusMessage = result.Message;

            if (result.Success)
            {
                newStandSectorName = string.Empty;
                await LoadEventStands();
            }
        }
        catch
        {
            isError = true;
            statusMessage = "Não foi possível criar a linha agora.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task RenameSector(string oldSector)
    {
        if (string.IsNullOrWhiteSpace(Session.AdminToken))
            return;

        var newSector = GetSectorDraftName(oldSector).Trim();
        if (string.IsNullOrWhiteSpace(newSector))
        {
            isError = true;
            statusMessage = "Informe um nome para a linha.";
            return;
        }

        isBusy = true;
        isError = false;
        statusMessage = string.Empty;
        var selectedCode = selectedStand?.Codigo;

        try
        {
            var result = await ApiClient.RenameStandSectorAsync(selectedStandEventId, oldSector, newSector, Session.AdminToken);
            isError = !result.Success;
            statusMessage = result.Message;

            if (result.Success)
            {
                sectorRenameInputs.Remove(oldSector);
                sectorRenameInputs[newSector] = newSector;
                await LoadEventStands();

                var selected = eventStands.FirstOrDefault(stand => string.Equals(stand.Codigo, selectedCode, StringComparison.OrdinalIgnoreCase));
                if (selected is not null)
                    SelectStand(selected);
            }
        }
        catch
        {
            isError = true;
            statusMessage = "Não foi possível renomear a linha agora.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task DeleteStandSector(string sectorName)
    {
        if (selectedStandEventId <= 0 || string.IsNullOrWhiteSpace(Session.AdminToken))
            return;

        isBusy = true;
        isError = false;
        statusMessage = string.Empty;

        try
        {
            var result = await ApiClient.DeleteStandSectorAsync(selectedStandEventId, sectorName, Session.AdminToken);
            isError = !result.Success;
            statusMessage = result.Message;

            if (result.Success)
                await LoadEventStands();
        }
        catch
        {
            isError = true;
            statusMessage = "Não foi possível excluir a linha agora.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private void BeginStandDrag(int standId)
    {
        draggedStandId = standId;
        SelectStand(eventStands.First(stand => stand.Id == standId));
    }

    private async Task DropStandOnSector(string sectorName)
    {
        if (draggedStandId <= 0)
            return;

        await MoveStandToSector(draggedStandId, sectorName);
        draggedStandId = 0;
    }

    private async Task MoveSelectedStandToSector(string sectorName)
    {
        if (selectedStand is null)
            return;

        await MoveStandToSector(selectedStand.Id, sectorName);
    }

    private async Task MoveStandToSector(int standId, string sectorName)
    {
        var stand = eventStands.FirstOrDefault(item => item.Id == standId);
        if (stand is null || string.IsNullOrWhiteSpace(Session.AdminToken))
            return;

        var targetSector = NormalizeStandSector(sectorName);
        await UpdateStandsBatch(
            [stand],
            item => BuildStandUpdateRequest(item, setor: targetSector),
            $"{stand.Codigo} movido para {targetSector}.",
            stand.Codigo);
    }

    private async Task DropStandOnMap(DragEventArgs args)
    {
        if (draggedStandId <= 0 || string.IsNullOrWhiteSpace(Session.AdminToken) || !HasStandMapImage)
            return;

        var stand = eventStands.FirstOrDefault(item => item.Id == draggedStandId);
        draggedStandId = 0;

        if (stand is null)
            return;

        try
        {
            var point = await JS.InvokeAsync<StandMapPoint>(
                "geekTopStandMap.getDropPoint",
                StandMapDropElementId,
                args.ClientX,
                args.ClientY);

            await UpdateStandMapPosition(stand, point.X, point.Y, $"Stand {stand.Codigo} posicionado na planta.");
        }
        catch
        {
            isError = true;
            statusMessage = "Não foi possível posicionar o stand na planta agora.";
        }
    }

    private async Task UpdateStandMapPosition(StandSpaceViewModel stand, double areaX, double areaY, string successMessage)
    {
        await UpdateStandsBatch(
            [stand],
            item =>
            {
                var request = BuildStandUpdateRequest(item);
                request.AreaX = Math.Clamp(areaX, 0, 100);
                request.AreaY = Math.Clamp(areaY, 0, 100);
                request.AreaLargura = item.AreaLargura <= 0 ? 10 : item.AreaLargura;
                request.AreaAltura = item.AreaAltura <= 0 ? 7 : item.AreaAltura;
                return request;
            },
            successMessage,
            stand.Codigo);
    }

    private async Task ApplyStandLayoutGrid(int gridSize)
    {
        if (eventStands.Count == 0 || string.IsNullOrWhiteSpace(Session.AdminToken))
        {
            isError = true;
            statusMessage = "Cadastre pelo menos um stand antes de organizar o mapa.";
            return;
        }

        if (eventStands.Count > gridSize * gridSize)
        {
            isError = true;
            statusMessage = $"A grade {gridSize}x{gridSize} comporta até {gridSize * gridSize} stand(s). Escolha uma grade maior.";
            return;
        }

        var points = BuildStandLayoutGrid(eventStands.Count, gridSize);
        var standWidth = GetStandLayoutWidth(eventStands.Count, gridSize);
        var standHeight = GetStandLayoutHeight(eventStands.Count, gridSize);
        var orderedStands = eventStands
            .OrderBy(stand => NormalizeStandSector(stand.Setor), StringComparer.OrdinalIgnoreCase)
            .ThenBy(stand => stand.Codigo, StringComparer.OrdinalIgnoreCase)
            .ToList();

        await UpdateStandsBatch(
            orderedStands,
            stand =>
            {
                var index = orderedStands.FindIndex(item => item.Id == stand.Id);
                var point = points[index];
                var request = BuildStandUpdateRequest(stand);
                request.AreaX = point.X;
                request.AreaY = point.Y;
                request.AreaLargura = standWidth;
                request.AreaAltura = standHeight;
                return request;
            },
            $"Grade {gridSize}x{gridSize} aplicada para {orderedStands.Count} stand(s). Você ainda pode arrastar e ajustar manualmente.",
            selectedStand?.Codigo);
    }

    private static List<StandMapPoint> BuildStandLayoutGrid(int standCount, int gridSize)
    {
        var columns = Math.Min(Math.Max(1, gridSize), Math.Max(1, (int)Math.Ceiling(Math.Sqrt(standCount))));
        var rows = Math.Max(1, (int)Math.Ceiling(standCount / (double)columns));
        var effectiveGridSize = Math.Max(columns, rows);

        var horizontalMargin = effectiveGridSize <= 2 ? 30.0 : effectiveGridSize <= 3 ? 24.0 : effectiveGridSize <= 5 ? 16.0 : 10.0;
        var verticalMargin = effectiveGridSize <= 2 ? 32.0 : effectiveGridSize <= 3 ? 26.0 : effectiveGridSize <= 5 ? 18.0 : 12.0;
        var usableWidth = 100 - horizontalMargin * 2;
        var usableHeight = 100 - verticalMargin * 2;
        var points = new List<StandMapPoint>(standCount);

        for (var index = 0; index < standCount; index++)
        {
            var column = index % columns;
            var row = index / columns;
            var x = columns == 1
                ? 50
                : horizontalMargin + (usableWidth * column / (columns - 1));
            var y = rows == 1
                ? 50
                : verticalMargin + (usableHeight * row / (rows - 1));

            points.Add(new StandMapPoint
            {
                X = Math.Clamp(x, 6, 94),
                Y = Math.Clamp(y, 8, 92)
            });
        }

        return points;
    }

    private static double GetStandLayoutWidth(int standCount, int gridSize)
    {
        var columns = Math.Min(Math.Max(1, gridSize), Math.Max(1, (int)Math.Ceiling(Math.Sqrt(standCount))));
        return Math.Clamp(72.0 / columns, 6.5, 12.0);
    }

    private static double GetStandLayoutHeight(int standCount, int gridSize)
    {
        var columns = Math.Min(Math.Max(1, gridSize), Math.Max(1, (int)Math.Ceiling(Math.Sqrt(standCount))));
        var rows = Math.Max(1, (int)Math.Ceiling(standCount / (double)columns));
        return Math.Clamp(52.0 / rows, 6.5, 9.0);
    }

    private string GetStandLayoutOptionTitle(StandLayoutOption option)
