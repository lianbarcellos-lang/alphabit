    private async Task AddGenreAsync(string genreName, Action<string> onSuccess)
    {
        if (string.IsNullOrWhiteSpace(Session.AdminToken))
            return;

        var trimmedGenre = genreName.Trim();
        if (string.IsNullOrWhiteSpace(trimmedGenre))
        {
            isError = true;
            statusMessage = "Informe uma categoria geek para cadastrar.";
            return;
        }

        isBusy = true;
        statusMessage = string.Empty;
        isError = false;

        try
        {
            var result = await ApiClient.CreateGenreAsync(new MusicGenreCreateRequest
            {
                Nome = trimmedGenre
            }, Session.AdminToken);

            isError = !result.Success;
            statusMessage = result.Message;

            if (result.Success)
            {
                await LoadGenresAsync();
                var selectedGenre = availableGenres.FirstOrDefault(genre =>
                    string.Equals(genre, trimmedGenre, StringComparison.OrdinalIgnoreCase)) ?? trimmedGenre;

                onSuccess(selectedGenre);
            }
        }
        catch
        {
            isError = true;
            statusMessage = "Não foi possível cadastrar a categoria geek agora.";
        }
        finally
        {
            isBusy = false;
        }
    }

