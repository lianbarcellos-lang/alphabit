            isError = !result.Success;
            statusMessage = result.Message;

            if (result.Success)
            {
                editingEvent = null;
                await LoadAdminEvents();
                await LoadAdminSalesDashboard();
            }
        }
        catch
        {
            isError = true;
            statusMessage = "Não foi possível atualizar o evento agora.";
        }
        finally
        {
            isBusy = false;
        }
    }

