    private static string GetPaymentMethodLabel(string paymentMethod)
    {
        return paymentMethod switch
        {
            "Cartão" => "Cartão",
            _ => paymentMethod
        };
    }

    private static string GetPaymentStatusLabel(string status)
    {
        return status switch
        {
            "Pendente" => "Pendente",
            "Cancelado" => "Cancelado",
            "Reembolsado" => "Reembolsado",
            _ => "Pago"
        };
    }

    private static string GetPaymentStatusClass(string status)
    {
        return status switch
        {
            "Pendente" => "admin-status-pill--pending",
            "Cancelado" => "admin-status-pill--cancelled",
