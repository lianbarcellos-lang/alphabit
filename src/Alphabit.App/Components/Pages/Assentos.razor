@page "/eventos/{Id:int}/assentos"
@inject NavigationManager Navigation

<PageTitle>Redirecionando</PageTitle>

<div class="seats-shell">
    <div class="status-box">Redirecionando para a compra do evento...</div>
</div>

@code {
    [Parameter] public int Id { get; set; }

    protected override void OnInitialized()
    {
        Navigation.NavigateTo($"/eventos/{Id}#compra", replace: true);
    }
}
