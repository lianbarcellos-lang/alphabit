@page "/"

@inject AlphabitApiClient ApiClient
@inject AuthOverlayState AuthOverlay
@inject NavigationManager Navigation
@inject UserSessionState Session

<PageTitle>GeekTop</PageTitle>

<div class="landing-shell">
    <section class="landing-hero">
        <div class="landing-hero__copy">
            <span class="eyebrow">Eventos geek, anime e games para descobrir agora</span>
            <h1>Encontre sua próxima convenção, torneio ou experiência de cultura pop.</h1>
            <p>Uma vitrine clara para pesquisar eventos, comparar categorias e garantir seu ingresso com segurança.</p>

            <div class="landing-search">
                <div class="landing-search__field">
                    <span>Busca em destaque</span>
                    <strong>Qual universo você quer viver nesta semana?</strong>
                </div>
                <button class="search-button" type="button" @onclick='() => Navigation.NavigateTo("/eventos")'>Buscar eventos</button>
            </div>

            <div class="landing-tags">
                <span>Anime</span>
                <span>Games</span>
                <span>Cosplay</span>
                <span>Card game</span>
                <span>São Paulo</span>
                <span>Rio de Janeiro</span>
            </div>

            <div class="landing-metrics">
                <div>
                    <strong>@featuredEvents.Count</strong>
                    <span>eventos em destaque</span>
                </div>
                <div>
                    <strong>@featuredCitiesCount</strong>
                    <span>cidades ativas</span>
                </div>
                <div>
                    <strong>Reserva fácil</strong>
                    <span>ingressos, carrinho e reservas</span>
                </div>
            </div>
        </div>

        <div class="landing-hero__banner">
            <article class="hero-banner hero-banner--large">
                <span>Em alta</span>
                <strong>Grandes encontros para fãs, jogadores e cosplayers</strong>
                <p>Descubra eventos com categoria clara, local definido e caminho direto para a reserva.</p>
            </article>
            <article class="hero-banner hero-banner--small">
                <span>Destaque do mês</span>
                <strong>Convenções, torneios e meet and greet</strong>
            </article>
        </div>
    </section>

    <section class="home-sections">
        <div class="section-head">
            <div>
                <span class="eyebrow">Eventos selecionados</span>
                <h2>Destaques para começar a jornada geek</h2>
            </div>
            <button class="ghost-button" type="button" @onclick='() => Navigation.NavigateTo("/eventos")'>Ver agenda completa</button>
        </div>

        <div class="home-event-grid">
            @foreach (var item in featuredEvents)
            {
                <article class="home-event-card">
                    @if (!string.IsNullOrWhiteSpace(item.ImagemUrl))
                    {
                        <img src="@item.ImagemUrl" alt="@item.Nome" />
                    }
                    <div class="home-event-card__body">
                        <span class="pill">@item.GeneroMusical</span>
                        <h3>@item.Nome</h3>
                        <p>@item.LocalEvento, @item.CidadeEvento</p>
                        <p>@item.DataEvento.ToString("dd/MM/yyyy 'as' HH:mm")</p>
                        <div class="home-event-card__footer">
                            <div class="home-event-card__pricing">
                                <strong>R$ @item.PrecoPadrao.ToString("0.00")</strong>
                                <span>@FormatRating(item)</span>
                            </div>
                            <div class="home-event-card__actions">
                                <button class="ghost-button" type="button" @onclick='() => Navigation.NavigateTo($"/eventos/{item.Id}")'>Ver ingressos</button>
                                <button class="secondary-button" type="button" @onclick='() => BuyEvent(item.Id)'>Comprar agora</button>
                            </div>
                        </div>
                    </div>
                </article>
            }
        </div>
    </section>

    <section class="home-showcase">
        <article class="showcase-panel">
            <span class="eyebrow">Categorias em alta</span>
            <h2>Filtros claros para cidade, data, local e categoria geek.</h2>
            <p>O público entende rápido onde clicar, compara eventos com menos atrito e avança melhor para a reserva.</p>
        </article>

        <article class="showcase-panel showcase-panel--dark">
            <span class="eyebrow">Fluxo de compra</span>
            <h2>Escolha o evento, veja atrações, selecione ingressos e finalize com carrinho.</h2>
            <p>Uma jornada em etapas para convenções, campeonatos, painéis e experiências presenciais.</p>
        </article>
    </section>

</div>

@code {
    private readonly List<EventViewModel> featuredEvents = [];
    private int featuredCitiesCount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            featuredEvents.Clear();
            featuredEvents.AddRange((await ApiClient.GetEventsAsync()).Take(3));
            featuredCitiesCount = featuredEvents
                .Select(item => item.CidadeEvento)
                .Where(item => !string.IsNullOrWhiteSpace(item))
                .Distinct()
                .Count();
        }
        catch
        {
            featuredCitiesCount = 0;
        }
    }

    private void BuyEvent(int eventId)
    {
        if (Session.CurrentUser is null)
        {
            AuthOverlay.OpenLogin();
            return;
        }

        Navigation.NavigateTo($"/eventos/{eventId}/assentos");
    }

    private static string FormatRating(EventViewModel item)
    {
        return item.TotalAvaliacoes == 0
            ? "Sem avaliações"
            : $"{item.MediaAvaliacoes:0.0}/5 ({item.TotalAvaliacoes})";
    }
}
